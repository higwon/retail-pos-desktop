<UserControl x:Class="RetailPOS.Desktop.Controls.NavigationHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1280">
    <UserControl.Resources>
        <Style x:Key="NavigationRailButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FF334155"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="46"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="190"/>
        </Grid.ColumnDefinitions>

        <Grid x:Name="ContentRoot"
              Grid.ColumnSpan="2"
              Background="{StaticResource AppBackgroundBrush}"/>

        <Border x:Name="DemoNavigation"
                Grid.Column="1"
                Visibility="Collapsed"
                Background="{StaticResource BrandDarkBrush}"
                BorderBrush="#FF334155"
                BorderThickness="1,0,0,0"
                Padding="10,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="8,2,8,18">
                    <TextBlock Text="Retail POS"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Cashier menu"
                               Foreground="#FFCBD5E1"
                               FontSize="11"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <Button x:Name="RegisterNavigationButton"
                            Style="{StaticResource NavigationRailButtonStyle}"
                            Click="OnShowRegister">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Path Data="{StaticResource IconCardGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="Register" Foreground="White" Margin="10,0,0,0"/></Grid>
                    </Button>
                    <Button x:Name="ProductSearchNavigationButton"
                            Style="{StaticResource NavigationRailButtonStyle}"
                            Click="OnShowProductSearch">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Path Data="{StaticResource IconSearchGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="Product Search" Foreground="White" Margin="10,0,0,0"/></Grid>
                    </Button>
                    <Button x:Name="RecoveryNavigationButton"
                            Style="{StaticResource NavigationRailButtonStyle}"
                            Click="OnShowRecovery">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Path Data="{StaticResource IconRecoveryGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="Recovery" Foreground="White" Margin="10,0,0,0"/></Grid>
                    </Button>
                    <Button x:Name="DashboardNavigationButton"
                            Style="{StaticResource NavigationRailButtonStyle}"
                            Click="OnShowDashboard">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Path Data="{StaticResource IconDashboardGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="Dashboard" Foreground="White" Margin="10,0,0,0"/></Grid>
                    </Button>
                    <Button x:Name="StatusNavigationButton"
                            Style="{StaticResource NavigationRailButtonStyle}"
                            Click="OnShowStatus">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Path Data="{StaticResource IconStatusGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="Status" Foreground="White" Margin="10,0,0,0"/></Grid>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="3">
                    <Button x:Name="DeviceSimulatorButton"
                            Style="{StaticResource NavigationRailButtonStyle}"
                            Click="OnOpenDeviceSimulator">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Path Data="{StaticResource IconDisplayGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="Simulator" Foreground="White" Margin="10,0,0,0"/></Grid>
                    </Button>
                    <Border BorderBrush="#FF475569"
                            BorderThickness="0,1,0,0"
                            Margin="0,5,0,10"/>
                    <Button
                            Style="{StaticResource NavigationRailButtonStyle}"
                            Click="OnSignOut">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Path Data="{StaticResource IconSignOutGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" HorizontalAlignment="Center"/><TextBlock Grid.Column="1" Text="Sign out" Foreground="White" Margin="10,0,0,0"/></Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="RetailPOS.Desktop.Controls.NavigationHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1280">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border x:Name="DemoNavigation" Visibility="Collapsed" Background="{StaticResource BrandDarkBrush}" Padding="20,10">
            <Grid>
                <TextBlock Text="Retail POS" Foreground="White" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Register" Style="{StaticResource SecondaryButtonStyle}" MinHeight="34" Padding="12,4" Margin="0,0,8,0" Click="OnShowRegister"/>
                    <Button Content="Recovery" Style="{StaticResource SecondaryButtonStyle}" MinHeight="34" Padding="12,4" Margin="0,0,8,0" Click="OnShowRecovery"/>
                    <Button Content="Dashboard" Style="{StaticResource SecondaryButtonStyle}" MinHeight="34" Padding="12,4" Margin="0,0,8,0" Click="OnShowDashboard"/>
                    <Button Content="Status" Style="{StaticResource SecondaryButtonStyle}" MinHeight="34" Padding="12,4" Margin="0,0,8,0" Click="OnShowStatus"/>
                    <Button x:Name="DeviceSimulatorButton" Content="Simulator" Style="{StaticResource SecondaryButtonStyle}" MinHeight="34" Padding="12,4" Click="OnOpenDeviceSimulator"/>
                    <Button Content="Sign out" Style="{StaticResource SecondaryButtonStyle}" MinHeight="34" Padding="12,4" Margin="8,0,0,0" Click="OnSignOut"/>
                </StackPanel>
            </Grid>
        </Border>
        <Grid x:Name="ContentRoot" Grid.RowSpan="2" Background="{StaticResource AppBackgroundBrush}" />
    </Grid>
</UserControl>

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    },
    "Desktop": {
      "LogDirectory": "",
      "RetainedFileCountLimit": 14
    }
  },
  "ApiSync": {
    "BaseAddress": "http://localhost:5000/"
  },
  "SyncScheduler": {
    "Enabled": true,
    "InitialDelaySeconds": 5,
    "IntervalSeconds": 60,
    "BatchSize": 10
  },
  "ApiConnectivity": {
    "Enabled": true,
    "InitialDelaySeconds": 2,
    "IntervalSeconds": 30,
    "TriggerSyncOnReconnect": true
  },
  "LocalDatabase": {}
}

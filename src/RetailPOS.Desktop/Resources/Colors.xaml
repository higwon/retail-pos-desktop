<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Color x:Key="ColorSurface">#FFFFFFFF</Color>
    <Color x:Key="ColorSurfaceMuted">#FFF6F8FA</Color>
    <Color x:Key="ColorBorder">#FFD8DEE4</Color>
    <Color x:Key="ColorTextPrimary">#FF111827</Color>
    <Color x:Key="ColorTextSecondary">#FF4B5563</Color>
    <Color x:Key="ColorPrimary">#FF0F766E</Color>
    <Color x:Key="ColorPrimaryHover">#FF115E59</Color>
    <Color x:Key="ColorDanger">#FFB42318</Color>
    <Color x:Key="ColorWarning">#FFB54708</Color>
    <Color x:Key="ColorSuccess">#FF027A48</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource ColorSurfaceMuted}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource ColorPrimaryHover}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource ColorWarning}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource ColorSuccess}" />
</ResourceDictionary>

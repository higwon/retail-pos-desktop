<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Color x:Key="ColorSurface">#FFFFFFFF</Color>
    <Color x:Key="ColorSurfaceMuted">#FFF6F8FA</Color>
    <Color x:Key="ColorBorder">#FFD8DEE4</Color>
    <Color x:Key="ColorTextPrimary">#FF111827</Color>
    <Color x:Key="ColorTextSecondary">#FF4B5563</Color>
    <Color x:Key="ColorPrimary">#FF2563EB</Color>
    <Color x:Key="ColorPrimaryHover">#FF1D4ED8</Color>
    <Color x:Key="ColorSecondaryButton">#FFEEF2FF</Color>
    <Color x:Key="ColorDanger">#FFDC2626</Color>
    <Color x:Key="ColorWarning">#FFB54708</Color>
    <Color x:Key="ColorSuccess">#FF027A48</Color>
    <Color x:Key="ColorBrandDark">#FF111827</Color>
    <Color x:Key="ColorBrandPanel">#FF1F2937</Color>
    <Color x:Key="ColorPrimaryBlue">#FF2563EB</Color>
    <Color x:Key="ColorPrimaryBlueHover">#FF1D4ED8</Color>
    <Color x:Key="ColorSelection">#FFEAF2F0</Color>
    <Color x:Key="ColorDangerMuted">#FFFEE2E2</Color>
    <Color x:Key="ColorWarningMuted">#FFFFF4E5</Color>
    <Color x:Key="ColorSuccessMuted">#FFECFDF3</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource ColorSurfaceMuted}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource ColorSurface}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource ColorBorder}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource ColorTextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource ColorTextSecondary}" />
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource ColorPrimary}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource ColorPrimaryHover}" />
    <SolidColorBrush x:Key="SecondaryButtonBrush" Color="{StaticResource ColorSecondaryButton}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource ColorWarning}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="BrandDarkBrush" Color="{StaticResource ColorBrandDark}" />
    <SolidColorBrush x:Key="BrandPanelBrush" Color="{StaticResource ColorBrandPanel}" />
    <SolidColorBrush x:Key="PrimaryBlueBrush" Color="{StaticResource ColorPrimaryBlue}" />
    <SolidColorBrush x:Key="PrimaryBlueHoverBrush" Color="{StaticResource ColorPrimaryBlueHover}" />
    <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource ColorSelection}" />
    <SolidColorBrush x:Key="DangerMutedBrush" Color="{StaticResource ColorDangerMuted}" />
    <SolidColorBrush x:Key="WarningMutedBrush" Color="{StaticResource ColorWarningMuted}" />
    <SolidColorBrush x:Key="SuccessMutedBrush" Color="{StaticResource ColorSuccessMuted}" />
</ResourceDictionary>

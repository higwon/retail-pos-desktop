    <Geometry x:Key="IconCalendarGeometry">M4,5 H20 V21 H4 Z M4,9 H20 M8,3 V7 M16,3 V7</Geometry>
    <Geometry x:Key="IconScannerGeometry">M5,5 H10 M5,5 V10 M19,5 H14 M19,5 V10 M5,19 H10 M5,19 V14 M19,19 H14 M19,19 V14 M9,8 V16 M12,8 V16 M15,8 V16</Geometry>

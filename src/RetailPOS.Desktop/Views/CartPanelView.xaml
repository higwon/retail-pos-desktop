<UserControl x:Class="RetailPOS.Desktop.Views.CartPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,18">
                <TextBlock Text="Shopping Cart" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="3 items" Style="{StaticResource SecondaryTextBlockStyle}" HorizontalAlignment="Right" />
            </DockPanel>

            <StackPanel Grid.Row="1">
                <Grid Margin="0,0,0,18"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Daily Shampoo" FontWeight="SemiBold"/><TextBlock Text="Qty 1" Style="{StaticResource SecondaryTextBlockStyle}" FontSize="12"/></StackPanel><TextBlock Grid.Column="1" Text="₩12,000" FontWeight="SemiBold"/></Grid>
                <Separator Background="{StaticResource BorderBrush}" />
                <Grid Margin="0,18"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Vitamin Drink" FontWeight="SemiBold"/><TextBlock Text="Qty 1" Style="{StaticResource SecondaryTextBlockStyle}" FontSize="12"/></StackPanel><TextBlock Grid.Column="1" Text="₩15,000" FontWeight="SemiBold"/></Grid>
                <Separator Background="{StaticResource BorderBrush}" />
                <Grid Margin="0,18"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Hand Cream" FontWeight="SemiBold"/><TextBlock Text="Qty 1" Style="{StaticResource SecondaryTextBlockStyle}" FontSize="12"/></StackPanel><TextBlock Grid.Column="1" Text="₩18,000" FontWeight="SemiBold"/></Grid>
            </StackPanel>

            <StackPanel Grid.Row="2">
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,22,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10"><TextBlock Text="Subtotal"/><TextBlock Text="₩42,000" HorizontalAlignment="Right"/></Grid>
                        <Grid Margin="0,0,0,18"><TextBlock Text="Discount"/><TextBlock Text="-₩2,000" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right"/></Grid>
                        <Grid Margin="0,0,0,24"><TextBlock Text="Total" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="₩40,000" FontSize="26" FontWeight="Bold" HorizontalAlignment="Right"/></Grid>
                    </StackPanel>
                </Border>
                <Button Content="Checkout" Style="{StaticResource PrimaryBlueButtonStyle}" Margin="0,0,0,10" />
                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions><Button Content="Hold Cart" Style="{StaticResource SecondaryButtonStyle}"/><Button Grid.Column="2" Content="Clear" Style="{StaticResource DangerMutedButtonStyle}"/></Grid>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

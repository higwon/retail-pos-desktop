<UserControl x:Class="RetailPOS.Desktop.Views.CartPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Border Style="{StaticResource PanelBorderStyle}" Padding="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Margin="0,0,0,18">
                <TextBlock Text="Shopping Cart" Style="{StaticResource TitleTextBlockStyle}" FontSize="22"/>
                <TextBlock HorizontalAlignment="Right" Style="{StaticResource SecondaryTextBlockStyle}">
                    <Run Text="{Binding ItemCount, Mode=OneWay}" /><Run Text=" items" />
                </TextBlock>
            </DockPanel>

            <Grid Grid.Row="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Lines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding LineTotal, StringFormat={}{0:N0} KRW}"
                                                       Style="{StaticResource SecondaryTextBlockStyle}"
                                                       Margin="0,4,0,8" />
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="-"
                                                        Command="{Binding DataContext.DecreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding ProductId}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Width="32" Height="30" Padding="0"
                                                        ToolTip="Decrease quantity" />
                                                <TextBlock Text="{Binding Quantity}"
                                                           Width="34"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                <Button Content="+"
                                                        Command="{Binding DataContext.IncreaseQuantityCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding ProductId}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Width="32" Height="30" Padding="0"
                                                        ToolTip="Increase quantity" />
                                            </StackPanel>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Remove"
                                                Command="{Binding DataContext.RemoveProductCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding ProductId}"
                                                Style="{StaticResource DangerMutedButtonStyle}"
                                                Padding="10,4"
                                                VerticalAlignment="Top" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Text="Cart is empty."
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>

            <StackPanel Grid.Row="2">
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,16,0,14">
                    <StackPanel>
                        <TextBlock Text="Manual discount" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding DiscountInput, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Enter a whole KRW amount or percentage rate" />
                            <Button Grid.Column="2" Content="KRW"
                                    Command="{Binding ApplyFixedDiscountCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="10,4" />
                            <Button Grid.Column="4" Content="%"
                                    Command="{Binding ApplyPercentageDiscountCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="42" Padding="8,4" />
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <TextBlock Text="{Binding DiscountErrorMessage}"
                                       Foreground="{StaticResource DangerBrush}"
                                       FontSize="12"
                                       Visibility="{Binding HasDiscountError, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="{Binding DiscountDescription}"
                                           Style="{StaticResource SecondaryTextBlockStyle}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <Button Content="Clear discount"
                                        Command="{Binding ClearDiscountCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        MinHeight="30" Padding="8,2" FontSize="12" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,22,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="Subtotal" />
                            <TextBlock Text="{Binding Subtotal, StringFormat={}{0:N0} KRW}" HorizontalAlignment="Right" />
                        </Grid>
                        <Grid Margin="0,0,0,18">
                            <TextBlock Text="Discount" />
                            <TextBlock Text="{Binding DiscountAmount, StringFormat={}{0:N0} KRW}"
                                       Foreground="{StaticResource SuccessBrush}"
                                       HorizontalAlignment="Right" />
                        </Grid>
                        <Grid Margin="0,0,0,24">
                            <TextBlock Text="Total" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Total, StringFormat={}{0:N0} KRW}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Border>
                <Button Content="Checkout"
                        Style="{StaticResource PrimaryBlueButtonStyle}"
                        Command="{Binding CheckoutCommand}"
                        Margin="0,0,0,10" />
                <Button Content="Clear cart"
                        Command="{Binding ClearCommand}"
                        Style="{StaticResource DangerMutedButtonStyle}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

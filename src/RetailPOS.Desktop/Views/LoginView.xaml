<UserControl x:Class="RetailPOS.Desktop.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1440">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource BrandDarkBrush}">
            <Grid Margin="72,64">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel>
                    <TextBlock Text="Retail POS" Foreground="White" FontSize="30" FontWeight="SemiBold" />
                    <TextBlock Text="Offline-first Windows POS system" Foreground="#FFAAB4C3" Margin="0,6,0,0" />
                </StackPanel>

                <Border Grid.Row="1" Width="440" Padding="32" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Background="{StaticResource BrandPanelBrush}"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="Reliable checkout even when the network is unavailable."
                                   Foreground="White" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="Local persistence, recoverable checkout, and background synchronization."
                                   Foreground="#FFCBD5E1" Margin="0,18,0,30" />
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#FFDCFCE7" CornerRadius="12" Padding="12,6" Margin="0,0,10,0">
                                <TextBlock Text="Offline Ready" Foreground="#FF166534" FontSize="12" />
                            </Border>
                            <Border Background="#FFE0E7FF" CornerRadius="12" Padding="12,6">
                                <TextBlock Text="Sync Queue" Foreground="#FF3730A3" FontSize="12" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Column="1" Background="#FFF8FAFD">
            <Border Width="410" Padding="40" Style="{StaticResource PanelBorderStyle}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Welcome back" FontSize="28" FontWeight="SemiBold" />
                    <TextBlock Text="Sign in to start a sales session." Style="{StaticResource SecondaryTextBlockStyle}"
                               Margin="0,8,0,30" />
                    <TextBlock Text="Employee Code" Margin="0,0,0,8" FontWeight="SemiBold" />
                    <TextBox Text="{Binding EmployeeCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" />
                    <TextBlock Text="Password" Margin="0,0,0,8" FontWeight="SemiBold" />
                    <PasswordBox MinHeight="44" Padding="12,8" Margin="0,0,0,28"
                                 BorderBrush="{StaticResource BorderBrush}"
                                 PasswordChanged="OnPasswordChanged" />
                    <Button Content="Sign in" Style="{StaticResource PrimaryBlueButtonStyle}"
                            Command="{Binding SignInCommand}" />
                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               Foreground="#FFB91C1C"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               HorizontalAlignment="Center"
                               Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"
                               Margin="0,14,0,0" />
                    <TextBlock Text="Offline sign-in uses the last verified access profile."
                               Style="{StaticResource SecondaryTextBlockStyle}" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,18,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

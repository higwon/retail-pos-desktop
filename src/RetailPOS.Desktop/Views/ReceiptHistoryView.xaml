<UserControl x:Class="RetailPOS.Desktop.Views.ReceiptHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             AutomationProperties.Name="Receipt history">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="ReceiptDatePickerTextBoxStyle"
               TargetType="DatePickerTextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0,4,0"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>
        <Style x:Key="ReceiptCalendarStyle" TargetType="Calendar">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="CalendarDayButton">
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsToday" Value="True">
                    <Setter Property="Foreground" Value="#FF1769FF"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFE8F1FF"/>
                    <Setter Property="Foreground" Value="#FF1769FF"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ReceiptListItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="RowBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="16,14">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#FFF1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#FFE8F1FF"/>
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="#FF1769FF"/>
                                <Setter TargetName="RowBorder" Property="BorderThickness" Value="4,0,0,1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="88"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CashierPageHeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Command="{Binding BackCommand}"
                        Style="{StaticResource CashierPageBackButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconBackGeometry}" Style="{StaticResource IconPathStyle}" Margin="0,0,8,0"/>
                        <TextBlock Text="Back"/>
                    </StackPanel>
                </Button>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Receipts" Style="{StaticResource CashierPageTitleTextStyle}"/>
                    <TextBlock Text="Completed sales and reprint history"
                               Style="{StaticResource CashierPageSubtitleTextStyle}"
                               Margin="0,5,0,0"/>
                </StackPanel>
                <Button Grid.Column="2"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconRefreshGeometry}" Style="{StaticResource IconPathStyle}" Margin="0,0,8,0"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <Border Style="{StaticResource PanelBorderStyle}" Padding="16" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Business date"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,7"/>
                    <Grid>
                        <DatePicker SelectedDate="{Binding SelectedDate}"
                                    MinHeight="44"
                                    Padding="0"
                                    Background="{StaticResource SurfaceBrush}"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    FontFamily="{StaticResource AppFontFamily}"
                                    FontSize="14"
                                    CalendarStyle="{StaticResource ReceiptCalendarStyle}"
                                    AutomationProperties.Name="Receipt business date">
                            <DatePicker.Resources>
                                <Style TargetType="DatePickerTextBox"
                                       BasedOn="{StaticResource ReceiptDatePickerTextBoxStyle}"/>
                            </DatePicker.Resources>
                        </DatePicker>
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="12,0">
                    <TextBlock Text="Order number"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,7"/>
                    <Grid>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 MinHeight="44"
                                 Padding="40,9,12,9"
                                 AutomationProperties.Name="Search receipts by order number"/>
                        <Path Data="{StaticResource IconSearchGeometry}"
                              Style="{StaticResource IconPathStyle}"
                              HorizontalAlignment="Left"
                              Margin="12,0,0,0"/>
                    </Grid>
                </StackPanel>
                <Button Grid.Column="2"
                        Command="{Binding SearchCommand}"
                        MinHeight="44"
                        VerticalAlignment="Bottom">
                    <TextBlock Text="Search" Foreground="White"/>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="440" MinWidth="360"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*" MinWidth="440"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid Background="#FFF8FAFC" Height="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Order / cashier" FontWeight="SemiBold" Margin="16,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Payment" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Total" FontWeight="SemiBold" Margin="0,0,16,0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Receipts}"
                             SelectedItem="{Binding SelectedReceipt, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource ReceiptListItemStyle}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             AutomationProperties.Name="Receipt results">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding OrderNumber}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,4,0,0">
                                            <Run Text="{Binding CompletedTimeText, Mode=OneWay}"/><Run Text="  "/><Run Text="{Binding CashierName, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding PaymentMethodText}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TotalAmountText}" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <ProgressBar Grid.Row="1"
                                 Height="3"
                                 VerticalAlignment="Top"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasReceipts}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Path Data="{StaticResource IconReceiptGeometry}" Style="{StaticResource IconPathStyle}" Width="34" Height="34" Stroke="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="No receipts found" FontSize="17" FontWeight="SemiBold" Margin="0,14,0,0"/>
                        <TextBlock Text="Change the date or order search."
                                   Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button Grid.Row="2" Command="{Binding LoadMoreCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="16,12"
                            Visibility="{Binding HasMore, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Load more"/>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <StackPanel>
                            <TextBlock Text="Receipt detail" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding OrderNumber}" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border Style="{StaticResource StatusPillStyle}" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <TextBlock Text="COMPLETED" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Row="1" Margin="0,18,0,12" VerticalScrollBarVisibility="Auto">
                        <StackPanel Visibility="{Binding HasDetail, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid Margin="0,0,0,5"><TextBlock Text="Completed" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="{Binding IssuedAtText}" HorizontalAlignment="Right"/></Grid>
                            <Grid Margin="0,0,0,5"><TextBlock Text="Business date" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="{Binding BusinessDateText}" HorizontalAlignment="Right"/></Grid>
                            <Grid Margin="0,0,0,5"><TextBlock Text="Cashier" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="{Binding CashierName}" HorizontalAlignment="Right"/></Grid>
                            <Grid Margin="0,0,0,16"><TextBlock Text="Register" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="{Binding RegisterName}" HorizontalAlignment="Right"/></Grid>

                            <Separator/>
                            <ItemsControl ItemsSource="{Binding Lines}" Margin="0,14,0,6">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="70"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding UnitPriceText}" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding QuantityText}" HorizontalAlignment="Right"/>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding TotalAmountText}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding DiscountAmountText}" Style="{StaticResource SecondaryTextBlockStyle}" HorizontalAlignment="Right" Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Separator/>
                            <Grid Margin="0,14,0,6"><TextBlock Text="Subtotal" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="{Binding SubtotalAmountText}" HorizontalAlignment="Right"/></Grid>
                            <Grid Margin="0,0,0,8"><TextBlock Text="Discount" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="{Binding DiscountAmountText}" HorizontalAlignment="Right"/></Grid>
                            <Grid Margin="0,0,0,16"><TextBlock Text="Total" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="{Binding TotalAmountText}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right"/></Grid>

                            <Separator/>
                            <ItemsControl ItemsSource="{Binding Payments}" Margin="0,14,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding MethodText}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding ApprovalCodeText}" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,3,0,0"/>
                                                <StackPanel Margin="0,4,0,0" Visibility="{Binding HasCashTenderDetails, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding CashTenderedText}" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                                    <TextBlock Text="{Binding ChangeText}" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding AmountText}" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                    <ProgressBar Grid.Row="1"
                                 Height="3"
                                 VerticalAlignment="Top"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IsDetailLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasDetail}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Path Data="{StaticResource IconReceiptGeometry}" Style="{StaticResource IconPathStyle}" Width="36" Height="36" Stroke="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="Select a receipt" FontSize="17" FontWeight="SemiBold" Margin="0,14,0,0"/>
                        <TextBlock Text="Receipt details load separately from the list."
                                   Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" VerticalAlignment="Center" AutomationProperties.LiveSetting="Assertive" Margin="0,0,150,0"/>
                        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" VerticalAlignment="Center" AutomationProperties.LiveSetting="Polite" Margin="0,0,150,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextBlockStyle}">
                                    <Style.Triggers><DataTrigger Binding="{Binding IsSuccessStatus}" Value="True"><Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/></DataTrigger></Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Command="{Binding PrintCommand}" HorizontalAlignment="Right" MinWidth="130">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconReceiptGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" Margin="0,0,8,0"/>
                                <TextBlock Text="Print / reprint" Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="RetailPOS.Desktop.Views.CheckoutRecoveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CashierPageHeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Button Click="OnBack" Style="{StaticResource CashierPageBackButtonStyle}">
                    <StackPanel Orientation="Horizontal"><Path Data="{StaticResource IconBackGeometry}" Style="{StaticResource IconPathStyle}" Margin="0,0,8,0"/><TextBlock Text="Back"/></StackPanel>
                </Button>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Checkout recovery" Style="{StaticResource CashierPageTitleTextStyle}"/>
                    <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource CashierPageSubtitleTextStyle}" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1.85*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1.05*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="20">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Recovery and review records"
                               FontSize="19"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>
                    <Grid>
                    <ListBox ItemsSource="{Binding Items}"
                             SelectedItem="{Binding SelectedItem}"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.Style>
                            <Style TargetType="ListBox"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding HasItems}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style>
                        </ListBox.Style>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Padding" Value="14"/><Setter Property="Margin" Value="0,0,0,8"/><Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/><Setter Property="BorderThickness" Value="1"/>
                                <Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="{StaticResource SelectionBrush}"/><Setter Property="BorderBrush" Value="#FF1769FF"/><Setter Property="BorderThickness" Value="2"/></Trigger></Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding CheckoutLabel}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CreatedAtText}"
                                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                                   Margin="0,3,0,0"/>
                                        <Grid Margin="0,8,0,0">
                                            <TextBlock Text="{Binding TerminalLabel}"
                                                       Style="{StaticResource SecondaryTextBlockStyle}"/>
                                            <TextBlock Text="{Binding ApprovedAmountText}"
                                                       HorizontalAlignment="Right"
                                                       FontWeight="SemiBold"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="16">
                        <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding HasItems}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                        <Border Width="54" Height="54" CornerRadius="27" Background="#FFE8F1FF" HorizontalAlignment="Center"><Path Data="{StaticResource IconRecoveryGeometry}" Style="{StaticResource IconPathStyle}" Width="26" Height="26" Stroke="#FF1769FF"/></Border>
                        <TextBlock Text="No recovery records" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                        <TextBlock Text="Interrupted or uncertain checkouts will appear here." Style="{StaticResource SecondaryTextBlockStyle}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0"/>
                    </StackPanel>
                    </Grid>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="28">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedItem.CheckoutLabel}"
                                       FontSize="19"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedItem.TerminalLabel}"
                                       Style="{StaticResource SecondaryTextBlockStyle}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>
                        <Border Style="{StaticResource StatusPillStyle}"
                                Background="{StaticResource WarningMutedBrush}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top">
                            <TextBlock Text="{Binding SelectedItem.StatusLabel}"
                                       Foreground="{StaticResource WarningBrush}"
                                       FontWeight="SemiBold"/>
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Row="1" Margin="0,28,0,20" VerticalScrollBarVisibility="Auto" Visibility="{Binding HasSelectedItem, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <Border Background="#FFFFF7ED" BorderBrush="#FFFED7AA" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,24">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource IconWarningGeometry}" Style="{StaticResource IconPathStyle}" Width="28" Height="28" Stroke="#FFEA580C" Margin="0,0,14,0" VerticalAlignment="Top"/>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedItem.WarningMessage}" Foreground="#FFC2410C" FontWeight="SemiBold" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="Cart snapshot" FontWeight="SemiBold" Margin="0,0,0,14"/>
                            <ItemsControl ItemsSource="{Binding SelectedItem.Lines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding ProductName}"/>
                                                <TextBlock Text="{Binding UnitPriceText}"
                                                           Style="{StaticResource SecondaryTextBlockStyle}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding QuantityText}"
                                                       HorizontalAlignment="Right"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding LineTotalText}"
                                                       HorizontalAlignment="Right"
                                                       FontWeight="SemiBold"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Separator Margin="0,16"/>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Subtotal" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <TextBlock Text="{Binding SelectedItem.CartSubtotalText}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Discount" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <TextBlock Text="{Binding SelectedItem.DiscountAmountText}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Approved amount" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <TextBlock Text="{Binding SelectedItem.ApprovedAmountText}"
                                           HorizontalAlignment="Right"
                                           Foreground="{StaticResource SuccessBrush}"
                                           FontWeight="SemiBold"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding HasSelectedItem}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                        <Path Data="{StaticResource IconReceiptGeometry}" Style="{StaticResource IconPathStyle}" Width="30" Height="30" Stroke="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Select a recovery record" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                        <TextBlock Text="Checkout details and the cart snapshot will appear here." Style="{StaticResource SecondaryTextBlockStyle}" TextAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2" Visibility="{Binding HasSelectedItem, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,14"/>
                        <TextBlock Grid.Row="1" Text="Total" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Text="{Binding SelectedItem.CartTotalText}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource PanelBorderStyle}" Padding="28">
                <StackPanel>
                    <TextBlock Text="Recovery actions" FontSize="19" FontWeight="SemiBold"/>
                    <TextBlock Text="Complete approved payments or route uncertain outcomes to review."
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               Margin="0,6,0,24"/>

                    <Button Command="{Binding CompleteOrderCommand}" Margin="0,0,0,10"><StackPanel Orientation="Horizontal"><Path Data="{StaticResource IconCheckGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" Margin="0,0,10,0"/><TextBlock Text="Complete order" Style="{StaticResource PrimaryButtonLabelTextStyle}"/></StackPanel></Button>
                    <Button Command="{Binding RequestManagerReviewCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10"><StackPanel Orientation="Horizontal"><Path Data="{StaticResource IconUserGeometry}" Style="{StaticResource IconPathStyle}" Margin="0,0,10,0"/><TextBlock Text="Request manager review"/></StackPanel></Button>
                    <Button Command="{Binding ResolveManagerReviewCommand}" Style="{StaticResource DangerMutedButtonStyle}" Margin="0,0,0,20"><StackPanel Orientation="Horizontal"><Path Data="{StaticResource IconShieldGeometry}" Style="{StaticResource IconPathStyle}" Stroke="{StaticResource DangerBrush}" Margin="0,0,10,0"/><TextBlock Text="Resolve and release"/></StackPanel></Button>
                    <Button Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButtonStyle}"><StackPanel Orientation="Horizontal"><Path Data="{StaticResource IconRefreshGeometry}" Style="{StaticResource IconPathStyle}" Margin="0,0,10,0"/><TextBlock Text="Refresh"/></StackPanel></Button>

                    <Separator Margin="0,24"/>
                    <TextBlock Text="Payment" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Approved at" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding SelectedItem.PaymentApprovedAtText}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Approval code" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding SelectedItem.ApprovalCode}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Reference" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding SelectedItem.TransactionReference}" HorizontalAlignment="Right"/>
                    </Grid>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"
                               Margin="0,20,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

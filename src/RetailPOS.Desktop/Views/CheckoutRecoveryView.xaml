<UserControl x:Class="RetailPOS.Desktop.Views.CheckoutRecoveryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="32,24"><StackPanel><TextBlock Text="Checkout recovery" Style="{StaticResource TitleTextBlockStyle}"/><TextBlock Text="Review an interrupted checkout before returning to the register." Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,6,0,0"/></StackPanel></Border>
        <Grid Grid.Row="1" Margin="32">
            <Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource PanelBorderStyle}" Padding="28">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid><StackPanel><TextBlock Text="Interrupted checkout" FontSize="19" FontWeight="SemiBold"/><TextBlock Text="Checkout #PC-00018 · Register 01" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,6,0,0"/></StackPanel><Border Style="{StaticResource StatusPillStyle}" Background="{StaticResource WarningMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Top"><TextBlock Text="REVIEW REQUIRED" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold"/></Border></Grid>
                    <StackPanel Grid.Row="1" Margin="0,32"><TextBlock Text="Cart snapshot" FontWeight="SemiBold" Margin="0,0,0,16"/><Grid Margin="0,0,0,12"><TextBlock Text="Daily Shampoo × 1"/><TextBlock Text="₩2,000" HorizontalAlignment="Right"/></Grid><Grid Margin="0,0,0,12"><TextBlock Text="Vitamin Drink × 1"/><TextBlock Text="₩5,000" HorizontalAlignment="Right"/></Grid><Grid><TextBlock Text="Hand Cream × 1"/><TextBlock Text="₩8,000" HorizontalAlignment="Right"/></Grid><Separator Margin="0,24"/><Grid><TextBlock Text="Payment state" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="Approval recorded" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right"/></Grid></StackPanel>
                    <Grid Grid.Row="2"><TextBlock Text="Total" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="₩15,000" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right"/></Grid>
                </Grid>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="28"><StackPanel><TextBlock Text="Recovery actions" FontSize="19" FontWeight="SemiBold"/><TextBlock Text="Choose how to handle this checkout." Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,6,0,26"/><Button Content="Complete order" Margin="0,0,0,10"/><Button Content="Return to register" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10"/><Button Content="Request manager review" Style="{StaticResource DangerMutedButtonStyle}"/><TextBlock Text="Demo shell only. These actions do not change data." Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,24,0,0"/></StackPanel></Border>
        </Grid>
    </Grid>
</UserControl>

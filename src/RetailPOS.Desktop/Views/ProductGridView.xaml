<UserControl x:Class="RetailPOS.Desktop.Views.ProductGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:RetailPOS.Desktop.Converters">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:ProductCategoryImageConverter x:Key="ProductCategoryImageConverter"/>
        <Style x:Key="ProductCodeCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource PosDataGridCellStyle}">
            <Setter Property="Padding" Value="24,0,12,0"/>
        </Style>
        <Style x:Key="ProductCodeHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource PosDataGridColumnHeaderStyle}">
            <Setter Property="Padding" Value="24,0,12,0"/>
        </Style>
        <Style x:Key="ProductCodeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource PosDataGridTextStyle}">
            <Setter Property="Margin" Value="24,0,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}"
          FocusManager.FocusedElement="{Binding ElementName=SearchInput}">
        <Grid.RowDefinitions>
            <RowDefinition Height="88"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CashierPageHeaderStyle}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding CancelCommand}"
                            Style="{StaticResource CashierPageBackButtonStyle}">
                        <StackPanel Orientation="Horizontal"><Path Data="{StaticResource IconBackGeometry}" Style="{StaticResource IconPathStyle}" Margin="0,0,8,0"/><TextBlock Text="Back"/></StackPanel>
                    </Button>
                    <TextBlock Text="Product Search"
                               Style="{StaticResource CashierPageTitleTextStyle}"/>
                </StackPanel>
                <TextBlock Text="Select a row, review the product, then choose a quantity."
                           Style="{StaticResource CashierPageSubtitleTextStyle}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Categories"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Categories}"
                             SelectedItem="{Binding SelectedCategory}"
                             BorderThickness="0"
                             Background="Transparent"
                             AutomationProperties.Name="Product categories">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="28"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Path Data="{StaticResource IconTagGeometry}" Style="{StaticResource IconPathStyle}" Stroke="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="Margin" Value="0,0,0,5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="214"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="20,18,20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="128"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <TextBox x:Name="SearchInput" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Padding="44,8,44,8" AutomationProperties.Name="Search by name, SKU, or barcode">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                                <KeyBinding Key="Escape" Command="{Binding CancelCommand}"/>
                            </TextBox.InputBindings>
                            </TextBox>
                            <Path Data="{StaticResource IconSearchGeometry}" Style="{StaticResource IconPathStyle}" HorizontalAlignment="Left" Margin="14,0,0,0"/>
                            <Path Data="{StaticResource IconScannerGeometry}" Style="{StaticResource IconPathStyle}" HorizontalAlignment="Right" Margin="0,0,14,0"/>
                        </Grid>
                        <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal"><Path Data="{StaticResource IconFilterGeometry}" Style="{StaticResource IconPathStyle}" Margin="0,0,8,0"/><TextBlock Text="Filter"/></StackPanel>
                        </Button>
                        <Button Grid.Column="2"
                                Content="Search"
                                Command="{Binding SearchCommand}"
                                Style="{StaticResource PrimaryBlueButtonStyle}"
                                MinWidth="96"
                                Margin="10,0,0,0"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="16,0,16,10">
                        <TextBlock Text="{Binding ProductResultsText}"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   AutomationProperties.LiveSetting="Polite"/>
                        <Button Content="Load more"
                                Command="{Binding LoadMoreProductsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                HorizontalAlignment="Right"
                                MinHeight="32"
                                Padding="10,3"
                                Visibility="{Binding HasMoreProducts, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>

                    <Grid Grid.Row="2">
                        <DataGrid ItemsSource="{Binding Products}"
                                  SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserResizeRows="False"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  CellStyle="{StaticResource PosDataGridCellStyle}"
                                  RowStyle="{StaticResource PosDataGridRowStyle}"
                                  ColumnHeaderStyle="{StaticResource PosDataGridColumnHeaderStyle}"
                                  RowHeaderWidth="0"
                                  RowHeight="48"
                                  ColumnHeaderHeight="40"
                                  BorderThickness="0,1,0,0"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  Background="{StaticResource SurfaceBrush}"
                                  AutomationProperties.Name="Product search results">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Code" Binding="{Binding Sku}" ElementStyle="{StaticResource ProductCodeTextStyle}"
                                                    CellStyle="{StaticResource ProductCodeCellStyle}" HeaderStyle="{StaticResource ProductCodeHeaderStyle}" Width="145"/>
                                <DataGridTextColumn Header="Product" Binding="{Binding Name}" ElementStyle="{StaticResource PosDataGridPrimaryTextStyle}" Width="*"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" ElementStyle="{StaticResource PosDataGridTextStyle}" Width="145"/>
                                <DataGridTextColumn Header="Price"
                                                    Binding="{Binding UnitPrice, StringFormat={}{0:N0} KRW}"
                                                    ElementStyle="{StaticResource PosDataGridNumberTextStyle}"
                                                    HeaderStyle="{StaticResource PosDataGridRightHeaderStyle}"
                                                    Width="130"/>
                                <DataGridTemplateColumn Header="Status" HeaderStyle="{StaticResource PosDataGridCenterHeaderStyle}" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource SuccessMutedBrush}" CornerRadius="12" Padding="10,4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock Text="Available" Foreground="{StaticResource SuccessBrush}" FontSize="12" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="Loading products..."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock Text="No products found."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"
                                   AutomationProperties.LiveSetting="Assertive"/>
                    </Grid>

                    <Border Grid.Row="3"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Background="{StaticResource SurfaceBrush}"
                            Padding="18">
                        <Grid>
                            <TextBlock Text="Select a product row to review details."
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextBlockStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasSelectedProduct}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Grid Visibility="{Binding HasSelectedProduct, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="190"/>
                                </Grid.ColumnDefinitions>

                                <Border Background="{StaticResource AppBackgroundBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        ClipToBounds="True">
                                    <Image Source="{Binding SelectedProduct.CategoryName, Converter={StaticResource ProductCategoryImageConverter}}"
                                           Stretch="UniformToFill"/>
                                </Border>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding SelectedProduct.Name}" FontSize="19" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <Border Background="{StaticResource SuccessMutedBrush}" CornerRadius="12" Padding="10,4" Margin="12,0,0,0"><TextBlock Text="Available" Foreground="{StaticResource SuccessBrush}" FontSize="12"/></Border>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,7,0,14"><Path Data="{StaticResource IconTagGeometry}" Style="{StaticResource IconPathStyle}" Stroke="#FF1769FF" Margin="0,0,7,0"/><TextBlock Text="{Binding SelectedProduct.CategoryName}" Foreground="#FF1769FF" FontWeight="SemiBold"/></StackPanel>
                                    <Grid Margin="0,0,0,7">
                                        <TextBlock Text="SKU" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                        <TextBlock Text="{Binding SelectedProduct.Sku}" Margin="84,0,0,0"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,7">
                                        <TextBlock Text="Barcode" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                        <TextBlock Text="{Binding SelectedProduct.Barcode}" Margin="84,0,0,0"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="Unit price" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                        <TextBlock Text="{Binding SelectedProduct.UnitPrice, StringFormat={}{0:N0} KRW}"
                                                   Margin="84,0,0,0"
                                                   FontWeight="SemiBold"/>
                                    </Grid>
                                </StackPanel>

                                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                    <TextBlock Text="Quantity"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Content="-"
                                                Command="{Binding DecreaseSelectedQuantityCommand}"
                                                Style="{StaticResource CompactStepperButtonStyle}"
                                                ToolTip="Decrease selected quantity"/>
                                        <TextBlock Text="{Binding SelectedQuantity}"
                                                   Width="54"
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"/>
                                        <Button Content="+"
                                                Command="{Binding IncreaseSelectedQuantityCommand}"
                                                Style="{StaticResource CompactStepperButtonStyle}"
                                                ToolTip="Increase selected quantity"/>
                                    </StackPanel>
                                    <Button Command="{Binding AddSelectedProductCommand}"
                                            Style="{StaticResource PrimaryBlueButtonStyle}"
                                            Margin="0,16,0,0"
                                            AutomationProperties.HelpText="Adds the selected quantity and returns to Register">
                                        <StackPanel Orientation="Horizontal"><Path Data="{StaticResource IconCartGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" Margin="0,0,9,0"/><TextBlock Text="Add to Cart" Foreground="White"/></StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<Window x:Class="RetailPOS.Desktop.Views.CustomerDisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:RetailPOS.Desktop.Converters"
        Title="Retail POS Customer Display"
        Width="1280" Height="720" MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#FF081526">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:ProductCategoryImageConverter x:Key="ProductCategoryImageConverter"/>
        <Style x:Key="DisplayPanelStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="#FFCED7E3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style x:Key="ProgressLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFC8D2E0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <Style x:Key="ProgressDetailStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF8998AC"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="28,22,28,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="58"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="106"/>
            <RowDefinition Height="22"/>
        </Grid.RowDefinitions>

        <Grid>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Retail POS" Foreground="White" FontSize="24" FontWeight="SemiBold"/>
                <TextBlock Text="Your purchase at a glance" Foreground="#FFA9B7C9" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>
            <TextBlock Text="Customer display"
                       Foreground="#FF8FA0B5"
                       FontSize="12"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource DisplayPanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="64"/>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="92"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Your order"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Margin="24,0"
                               VerticalAlignment="Center"/>

                    <Border Grid.Row="1" Background="#FFF4F7FA" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1">
                        <Grid Margin="24,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="82"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Item" Style="{StaticResource SecondaryTextBlockStyle}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Qty" Style="{StaticResource SecondaryTextBlockStyle}" FontWeight="SemiBold" TextAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="Amount" Style="{StaticResource SecondaryTextBlockStyle}" FontWeight="SemiBold" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Lines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="18,10">
                                            <Grid MinHeight="62">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="68"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="82"/>
                                                    <ColumnDefinition Width="130"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Width="56" Height="56" CornerRadius="5" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Background="#FFF8FAFC" HorizontalAlignment="Left">
                                                    <Image Source="{Binding CategoryName, Converter={StaticResource ProductCategoryImageConverter}}" Stretch="Uniform" Margin="5"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,12,0">
                                                    <TextBlock Text="{Binding ProductName}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding UnitPriceText}" Style="{StaticResource SecondaryTextBlockStyle}" FontSize="12" Margin="0,4,0,0"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding QuantityText}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="{Binding LineTotalText}" FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border Width="54" Height="54" CornerRadius="27" Background="#FFE8F1FF" HorizontalAlignment="Center">
                                <Path Data="{StaticResource IconCartGeometry}" Style="{StaticResource IconPathStyle}" Width="26" Height="26" Stroke="{StaticResource PrimaryBlueBrush}"/>
                            </Border>
                            <TextBlock Text="Your order will appear here" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                            <TextBlock Text="Items are added as they are scanned." Style="{StaticResource SecondaryTextBlockStyle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="3" Background="#FFF4F7FA" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="22,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="230"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="{StaticResource IconCartGeometry}" Style="{StaticResource IconPathStyle}" Width="28" Height="28" Stroke="{StaticResource TextPrimaryBrush}" Margin="0,0,14,0"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding ItemSummary}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding QuantitySummary}" Style="{StaticResource SecondaryTextBlockStyle}" FontSize="12" Margin="0,3,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Subtotal" Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding SubtotalAmount}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Text="{Binding DiscountLabel}" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center" Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <TextBlock Grid.Row="1" Text="{Binding DiscountSummary}" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"/>
                                <TextBlock Grid.Row="2" Text="Total" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Bottom"/>
                                <TextBlock Grid.Row="2" Text="{Binding TotalAmount}" FontSize="21" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource DisplayPanelStyle}">
                <Grid Margin="28">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360">
                        <Border Width="86" Height="86" CornerRadius="43" Background="{Binding StatusMutedBrush}" HorizontalAlignment="Center">
                            <Path Width="40" Height="40" Stretch="Uniform" Stroke="{Binding StatusAccentBrush}" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource IconCartGeometry}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPaymentActive}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource IconCardGeometry}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPaymentProblem}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource IconWarningGeometry}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCompletedActive}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource IconCheckGeometry}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Border>

                        <StackPanel Margin="0,18,0,0" Visibility="{Binding IsAmountVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Amount to pay" Style="{StaticResource SecondaryTextBlockStyle}" FontSize="15" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding AmountToPayText}" FontSize="38" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="NoWrap"/>
                        </StackPanel>

                        <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,22" MinWidth="240"/>
                        <TextBlock Text="{Binding StatusHeading}" Foreground="{Binding StatusAccentBrush}" FontSize="19" FontWeight="SemiBold" TextAlignment="Center"/>
                        <TextBlock Text="{Binding PaymentMessage}" Style="{StaticResource SecondaryTextBlockStyle}" FontSize="14" TextAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,0" AutomationProperties.LiveSetting="Polite"/>
                        <TextBlock Text="{Binding PaymentMethodText}" Foreground="{Binding StatusAccentBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,14,0,0" Visibility="{Binding IsPaymentActive, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#FF122238" BorderBrush="#FF263A52" BorderThickness="1" CornerRadius="6" Padding="22,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="38" Height="38" CornerRadius="19" VerticalAlignment="Top">
                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#FF536176"/><Style.Triggers><DataTrigger Binding="{Binding IsReviewOrderActive}" Value="True"><Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/></DataTrigger></Style.Triggers></Style></Border.Style>
                        <Path Data="{StaticResource IconReceiptGeometry}" Style="{StaticResource IconPathStyle}" Width="19" Height="19" Stroke="White"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="8,2,12,0">
                        <TextBlock Text="Review order" Style="{StaticResource ProgressLabelStyle}" TextAlignment="Left"/>
                        <TextBlock Text="Check items and total" Style="{StaticResource ProgressDetailStyle}" TextAlignment="Left"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="38" Height="38" CornerRadius="19" VerticalAlignment="Top">
                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#FF536176"/><Style.Triggers><DataTrigger Binding="{Binding IsPaymentActive}" Value="True"><Setter Property="Background" Value="{StaticResource PrimaryBlueBrush}"/></DataTrigger></Style.Triggers></Style></Border.Style>
                        <Path Data="{StaticResource IconCardGeometry}" Style="{StaticResource IconPathStyle}" Width="19" Height="19" Stroke="White"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="8,2,12,0">
                        <TextBlock Text="{Binding PaymentMethodText}" Style="{StaticResource ProgressLabelStyle}" TextAlignment="Left"/>
                        <TextBlock Text="Processing payment" Style="{StaticResource ProgressDetailStyle}" TextAlignment="Left"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="38" Height="38" CornerRadius="19" VerticalAlignment="Top">
                        <Border.Style><Style TargetType="Border"><Setter Property="Background" Value="#FF536176"/><Style.Triggers><DataTrigger Binding="{Binding IsCompletedActive}" Value="True"><Setter Property="Background" Value="{StaticResource SuccessBrush}"/></DataTrigger></Style.Triggers></Style></Border.Style>
                        <Path Data="{StaticResource IconCheckGeometry}" Style="{StaticResource IconPathStyle}" Width="19" Height="19" Stroke="White"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="8,2,0,0">
                        <TextBlock Text="Completed" Style="{StaticResource ProgressLabelStyle}" TextAlignment="Left"/>
                        <TextBlock Text="Please take your receipt" Style="{StaticResource ProgressDetailStyle}" TextAlignment="Left"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <TextBlock Grid.Row="3" Text="Thank you for shopping with us."
                   Foreground="#FF8291A5" HorizontalAlignment="Center" VerticalAlignment="Bottom" FontSize="11"/>
    </Grid>
</Window>

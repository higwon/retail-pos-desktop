<Window x:Class="RetailPOS.Desktop.Views.CustomerDisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Retail POS Customer Display"
        Width="1280" Height="720" MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrandDarkBrush}">
    <Grid Margin="64,48">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <StackPanel>
                <TextBlock Text="Retail POS" Foreground="White" FontSize="26" FontWeight="SemiBold" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="#FFAAB4C3" Margin="0,6,0,0" />
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="#FFDCFCE7" CornerRadius="12" Padding="12,6">
                <TextBlock Text="Online" Foreground="#FF166534" FontSize="12" />
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,50,0,42">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}" Padding="32">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Your order" FontSize="24" FontWeight="SemiBold" />
                    <StackPanel Grid.Row="1" Margin="0,28">
                        <Grid Margin="0,0,0,22"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Daily Shampoo" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="Qty 1" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,5,0,0"/></StackPanel><TextBlock Grid.Column="1" Text="₩12,000" FontSize="17" FontWeight="SemiBold"/></Grid>
                        <Separator Background="{StaticResource BorderBrush}" />
                        <Grid Margin="0,22"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Vitamin Drink" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="Qty 1" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,5,0,0"/></StackPanel><TextBlock Grid.Column="1" Text="₩15,000" FontSize="17" FontWeight="SemiBold"/></Grid>
                        <Separator Background="{StaticResource BorderBrush}" />
                        <Grid Margin="0,22,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Hand Cream" FontSize="17" FontWeight="SemiBold"/><TextBlock Text="Qty 1" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,5,0,0"/></StackPanel><TextBlock Grid.Column="1" Text="₩18,000" FontSize="17" FontWeight="SemiBold"/></Grid>
                    </StackPanel>
                    <Grid Grid.Row="2"><TextBlock Text="3 items" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="Discount  -₩2,000" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right"/></Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="38">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Amount to pay" Style="{StaticResource SecondaryTextBlockStyle}" FontSize="16" HorizontalAlignment="Center" />
                    <TextBlock Text="{Binding TotalAmount}" FontSize="52" FontWeight="Bold" Margin="0,18,0,28" HorizontalAlignment="Center" />
                    <Border Background="{StaticResource SelectionBrush}" CornerRadius="6" Padding="24,14">
                        <TextBlock Text="{Binding PaymentMessage}" Foreground="{StaticResource PrimaryBlueBrush}" FontSize="17" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Text="Thank you for shopping with us."
                   Foreground="#FFAAB4C3" HorizontalAlignment="Center" FontSize="15" />
    </Grid>
</Window>

<UserControl x:Class="RetailPOS.Desktop.Views.StatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources><BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/></UserControl.Resources>
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="88" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CashierPageHeaderStyle}"><Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Button Click="OnBack" Style="{StaticResource CashierPageBackButtonStyle}">
                <StackPanel Orientation="Horizontal"><Path Data="{StaticResource IconBackGeometry}" Style="{StaticResource IconPathStyle}" Margin="0,0,8,0"/><TextBlock Text="Back"/></StackPanel>
            </Button>
            <Grid Grid.Column="1" VerticalAlignment="Center">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <TextBlock Text="System status" Style="{StaticResource CashierPageTitleTextStyle}" />
                <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Margin="0,5,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource CashierPageSubtitleTextStyle}">
                            <Style.Triggers><DataTrigger Binding="{Binding HasError}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Row="1" Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="0,5,0,0"
                           Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"
                           AutomationProperties.LiveSetting="Assertive" />
            </Grid>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="{Binding LastCheckedText}" Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" Margin="0,0,16,0" />
                <Button Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"><StackPanel Orientation="Horizontal"><Path Data="{StaticResource IconRefreshGeometry}" Style="{StaticResource IconPathStyle}" Margin="0,0,8,0"/><TextBlock Text="Refresh"/></StackPanel></Button>
                <Button Command="{Binding RunSyncCommand}"><StackPanel Orientation="Horizontal"><Path Data="{StaticResource IconRefreshGeometry}" Style="{StaticResource IconPathStyle}" Stroke="White" Margin="0,0,8,0"/><TextBlock Text="Run sync" Foreground="White"/></StackPanel></Button>
            </StackPanel>
        </Grid></Border>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Devices}" Margin="24,20,24,16">
            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="4"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate><DataTemplate>
                <Border Style="{StaticResource PanelBorderStyle}" Padding="20" Margin="0,0,12,0">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Width="50" Height="50" CornerRadius="8" Background="#FFE8F1FF" VerticalAlignment="Top"><Path x:Name="DeviceIcon" Data="{StaticResource IconDisplayGeometry}" Style="{StaticResource IconPathStyle}" Width="28" Height="28" Stroke="#FF1769FF"/></Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="16"/>
                        <Border Background="{Binding BadgeBackground}" CornerRadius="10" Padding="9,3"
                                HorizontalAlignment="Left" Margin="0,7,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Availability}" Foreground="{Binding BadgeForeground}"/>
                                <TextBlock Text=" · " Foreground="{Binding BadgeForeground}"/>
                                <TextBlock Text="{Binding Readiness}" Foreground="{Binding BadgeForeground}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Margin="0,7,0,0"/>
                        <TextBlock Text="{Binding LastChangedText}" Style="{StaticResource SecondaryTextBlockStyle}" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel></Grid>
                </Border>
                <DataTemplate.Triggers>
                    <DataTrigger Binding="{Binding DisplayName}" Value="Barcode scanner"><Setter TargetName="DeviceIcon" Property="Data" Value="{StaticResource IconScannerGeometry}"/></DataTrigger>
                    <DataTrigger Binding="{Binding DisplayName}" Value="Receipt printer"><Setter TargetName="DeviceIcon" Property="Data" Value="{StaticResource IconReceiptGeometry}"/></DataTrigger>
                    <DataTrigger Binding="{Binding DisplayName}" Value="Card terminal"><Setter TargetName="DeviceIcon" Property="Data" Value="{StaticResource IconCardGeometry}"/></DataTrigger>
                </DataTemplate.Triggers>
            </DataTemplate></ItemsControl.ItemTemplate>
        </ItemsControl>

        <UniformGrid Grid.Row="2" Columns="4" Margin="24,0,24,16">
            <Border Style="{StaticResource PanelBorderStyle}" Padding="20" Margin="0,0,12,0">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="54"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Width="42" Height="42" CornerRadius="8" Background="#FFE8F1FF"><Path Data="{StaticResource IconClockGeometry}" Style="{StaticResource IconPathStyle}" Width="24" Height="24" Stroke="#FF1769FF"/></Border><StackPanel Grid.Column="1">
                    <TextBlock Text="Pending" Style="{StaticResource SecondaryTextBlockStyle}" />
                    <TextBlock Text="{Binding PendingCountText}" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0" />
                </StackPanel></Grid>
            </Border>
            <Border Style="{StaticResource PanelBorderStyle}" Padding="20" Margin="0,0,12,0">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="54"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Width="42" Height="42" CornerRadius="8" Background="#FFE8F1FF"><Path Data="{StaticResource IconRefreshGeometry}" Style="{StaticResource IconPathStyle}" Width="24" Height="24" Stroke="#FF1769FF"/></Border><StackPanel Grid.Column="1">
                    <TextBlock Text="Retrying" Style="{StaticResource SecondaryTextBlockStyle}" />
                    <TextBlock Text="{Binding RetryCountText}" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0" />
                </StackPanel></Grid>
            </Border>
            <Border Style="{StaticResource PanelBorderStyle}" Padding="20" Margin="0,0,12,0">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="54"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Width="42" Height="42" CornerRadius="8" Background="#FFE8F1FF"><Path Data="{StaticResource IconInfoGeometry}" Style="{StaticResource IconPathStyle}" Width="24" Height="24" Stroke="#FF1769FF"/></Border><StackPanel Grid.Column="1">
                    <TextBlock Text="Needs review" Style="{StaticResource SecondaryTextBlockStyle}" />
                    <TextBlock Text="{Binding ReviewCountText}" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0" />
                </StackPanel></Grid>
            </Border>
            <Border Style="{StaticResource PanelBorderStyle}" Padding="20">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="54"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Width="42" Height="42" CornerRadius="8" Background="#FFE8F1FF"><Path Data="{StaticResource IconCheckGeometry}" Style="{StaticResource IconPathStyle}" Width="24" Height="24" Stroke="#FF1769FF"/></Border><StackPanel Grid.Column="1">
                    <TextBlock Text="Completed" Style="{StaticResource SecondaryTextBlockStyle}" />
                    <TextBlock Text="{Binding CompletedCountText}" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0" />
                </StackPanel></Grid>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="3" Margin="24,0,24,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Synchronization queue" FontSize="18" FontWeight="SemiBold" />
                    <ListBox Grid.Row="1"
                             Margin="0,20,0,0"
                             ItemsSource="{Binding Items}"
                             SelectedItem="{Binding SelectedItem}"
                             BorderThickness="0"
                             Background="Transparent"
                             Visibility="{Binding HasItems, Converter={StaticResource BooleanToVisibilityConverter}}"
                             AutomationProperties.Name="Synchronization queue">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding CreatedAtText}" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center" Margin="16,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding HasItems}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                        <Border Width="54" Height="54" CornerRadius="27" Background="#FFE8F1FF" HorizontalAlignment="Center"><Path Data="{StaticResource IconRefreshGeometry}" Style="{StaticResource IconPathStyle}" Width="25" Height="25" Stroke="#FF1769FF"/></Border>
                        <TextBlock Text="Synchronization queue is empty" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                        <TextBlock Text="New local changes will appear here until synchronization completes." Style="{StaticResource SecondaryTextBlockStyle}" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="360" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="24">
                <Grid>
                <StackPanel Visibility="{Binding HasSelectedItem, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Queue item details" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedItem.Title}" FontSize="20" FontWeight="SemiBold" Margin="0,24,0,18" />
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10"><Grid>
                        <TextBlock Text="Status" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{Binding SelectedItem.StatusText}" HorizontalAlignment="Right" />
                    </Grid></Border>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10"><Grid>
                        <TextBlock Text="Attempts" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{Binding SelectedItem.RetryCountText}" HorizontalAlignment="Right" />
                    </Grid></Border>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10"><Grid>
                        <TextBlock Text="Next attempt" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{Binding SelectedItem.NextAttemptText}" HorizontalAlignment="Right" />
                    </Grid></Border>
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10" Margin="0,0,0,10"><Grid>
                        <TextBlock Text="Updated" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{Binding SelectedItem.UpdatedAtText}" HorizontalAlignment="Right" />
                    </Grid></Border>
                    <TextBlock Text="Last error" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,12,0,6" />
                    <TextBlock Text="{Binding SelectedItem.LastErrorSummary}" TextWrapping="Wrap" />
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,16,0,0" />
                    <TextBlock Text="Reference" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,14,0,6" />
                    <TextBlock Text="{Binding SelectedItem.ReferenceKeyShort}" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding SelectedItem.ReferenceKeyShort}" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel.Style><Style TargetType="StackPanel"><Setter Property="Visibility" Value="Visible"/><Style.Triggers><DataTrigger Binding="{Binding HasSelectedItem}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></StackPanel.Style>
                    <Path Data="{StaticResource IconInfoGeometry}" Style="{StaticResource IconPathStyle}" Width="30" Height="30" Stroke="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="No queue item selected" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                    <TextBlock Text="Select an item to review synchronization details." Style="{StaticResource SecondaryTextBlockStyle}" TextAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

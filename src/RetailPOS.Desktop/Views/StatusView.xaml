<UserControl x:Class="RetailPOS.Desktop.Views.StatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource AppBackgroundBrush}" Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <StackPanel>
                <TextBlock Text="System status" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,6,0,0" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" Margin="0,8,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="{Binding LastCheckedText}" Style="{StaticResource SecondaryTextBlockStyle}" VerticalAlignment="Center" Margin="0,0,16,0" />
                <Button Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0" />
                <Button Content="Run sync" Command="{Binding RunSyncCommand}" />
            </StackPanel>
        </Grid>

        <ItemsControl Grid.Row="1" ItemsSource="{Binding Devices}" Margin="0,24,0,20">
            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="4"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate><DataTemplate>
                <Border Style="{StaticResource PanelBorderStyle}" Padding="16" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="16"/>
                        <Border Background="{Binding BadgeBackground}" CornerRadius="10" Padding="9,3"
                                HorizontalAlignment="Left" Margin="0,7,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Availability}" Foreground="{Binding BadgeForeground}"/>
                                <TextBlock Text=" · " Foreground="{Binding BadgeForeground}"/>
                                <TextBlock Text="{Binding Readiness}" Foreground="{Binding BadgeForeground}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="{Binding Detail}" TextWrapping="Wrap" Margin="0,7,0,0"/>
                        <TextBlock Text="{Binding LastChangedText}" Style="{StaticResource SecondaryTextBlockStyle}" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </DataTemplate></ItemsControl.ItemTemplate>
        </ItemsControl>

        <UniformGrid Grid.Row="2" Columns="4" Margin="0,0,0,20">
            <Border Style="{StaticResource PanelBorderStyle}" Padding="20" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Pending" Style="{StaticResource SecondaryTextBlockStyle}" />
                    <TextBlock Text="{Binding PendingCountText}" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorderStyle}" Padding="20" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Retrying" Style="{StaticResource SecondaryTextBlockStyle}" />
                    <TextBlock Text="{Binding RetryCountText}" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorderStyle}" Padding="20" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Needs review" Style="{StaticResource SecondaryTextBlockStyle}" />
                    <TextBlock Text="{Binding ReviewCountText}" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorderStyle}" Padding="20">
                <StackPanel>
                    <TextBlock Text="Completed" Style="{StaticResource SecondaryTextBlockStyle}" />
                    <TextBlock Text="{Binding CompletedCountText}" FontSize="20" FontWeight="SemiBold" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Synchronization queue" FontSize="18" FontWeight="SemiBold" />
                    <ListBox Grid.Row="1"
                             Margin="0,20,0,0"
                             ItemsSource="{Binding Items}"
                             SelectedItem="{Binding SelectedItem}"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding CreatedAtText}" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding StatusText}" VerticalAlignment="Center" Margin="16,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="24">
                <StackPanel>
                    <TextBlock Text="Queue item details" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedItem.Title}" FontSize="20" FontWeight="SemiBold" Margin="0,24,0,18" />
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Status" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{Binding SelectedItem.StatusText}" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Attempts" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{Binding SelectedItem.RetryCountText}" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Next attempt" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{Binding SelectedItem.NextAttemptText}" HorizontalAlignment="Right" />
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Updated" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{Binding SelectedItem.UpdatedAtText}" HorizontalAlignment="Right" />
                    </Grid>
                    <TextBlock Text="Last error" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,12,0,6" />
                    <TextBlock Text="{Binding SelectedItem.LastErrorSummary}" TextWrapping="Wrap" />
                    <TextBlock Text="Reference" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,18,0,6" />
                    <TextBlock Text="{Binding SelectedItem.ReferenceKeyShort}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

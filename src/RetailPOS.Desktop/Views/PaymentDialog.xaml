<Window x:Class="RetailPOS.Desktop.Views.PaymentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Payment" Width="520" Height="600" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="32">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid>
            <StackPanel><TextBlock Text="Payment" Style="{StaticResource TitleTextBlockStyle}"/><TextBlock Text="Choose a payment method" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,6,0,0"/></StackPanel>
            <Button Content="Close" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Right" MinHeight="36" Padding="14,4" Click="OnClose"/>
        </Grid>
        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Padding="28" Margin="0,24,0,0">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Amount due" Style="{StaticResource SecondaryTextBlockStyle}" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding TotalAmount}" FontSize="38" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,12,0,30"/>
                <Button Content="Card payment"
                        Command="{Binding ApproveCardPaymentCommand}"
                        Style="{StaticResource PrimaryBlueButtonStyle}"
                        Margin="0,0,0,12"/>
                <Button Content="Cash payment"
                        Command="{Binding ApproveCashPaymentCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"/>
                <TextBlock Text="{Binding Message}"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,24,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextBlockStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsApproved}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsUnknown}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Approval code" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding ApprovalCode, TargetNullValue=-}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Transaction reference" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding TransactionReference, TargetNullValue=-}" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>
        <TextBlock Grid.Row="2" Text="Local payment devices only. No external gateway is used." Style="{StaticResource SecondaryTextBlockStyle}" HorizontalAlignment="Center" Margin="0,20,0,0"/>
    </Grid>
</Window>

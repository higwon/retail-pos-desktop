<Window x:Class="RetailPOS.Desktop.Views.ReceiptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receipt" Width="760" Height="840" MinWidth="700" MinHeight="700"
        WindowStartupLocation="CenterOwner" Background="{StaticResource AppBackgroundBrush}"
        KeyboardNavigation.TabNavigation="Cycle"
        AutomationProperties.Name="Receipt preview">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <StackPanel>
                <TextBlock Text="Payment complete" Style="{StaticResource TitleTextBlockStyle}"/>
                <Grid Margin="0,6,140,0">
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" AutomationProperties.LiveSetting="Polite">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextBlockStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSuccessStatus}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource DangerBrush}"
                               TextWrapping="Wrap"
                               AutomationProperties.LiveSetting="Assertive"/>
                </Grid>
            </StackPanel>
            <Border Style="{StaticResource StatusPillStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">
                <TextBlock Text="PAID"
                           Foreground="{StaticResource SuccessBrush}"
                           FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Margin="12,24" Padding="28">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="{Binding StoreName}"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StoreAddress}"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,18"/>

                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Receipt" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding OrderNumber}" HorizontalAlignment="Right"
                                   TextTrimming="CharacterEllipsis" Margin="100,0,0,0"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Business date" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding BusinessDateText}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Issued" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding IssuedAtText}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Cashier" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding CashierName}" HorizontalAlignment="Right"
                                   TextTrimming="CharacterEllipsis" Margin="100,0,0,0"/>
                    </Grid>
                    <Grid Margin="0,0,0,18">
                        <TextBlock Text="Register" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding RegisterName}" HorizontalAlignment="Right"
                                   TextTrimming="CharacterEllipsis" Margin="100,0,0,0"/>
                    </Grid>

                    <Separator/>
                    <ItemsControl ItemsSource="{Binding Lines}" Margin="0,18,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding UnitPriceText}"
                                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding DiscountAmountText}"
                                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding QuantityText}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TotalAmountText}"
                                               HorizontalAlignment="Right"
                                               FontWeight="SemiBold"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator/>
                    <Grid Margin="0,18,0,8">
                        <TextBlock Text="Subtotal" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding SubtotalAmount}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Discount" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding DiscountAmount}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,18">
                        <TextBlock Text="Total" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalAmount}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator/>
                    <ItemsControl ItemsSource="{Binding Payments}" Margin="0,18,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding MethodText}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding ApprovalCodeText}"
                                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding AmountText}"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource SuccessBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Thank you for shopping with us."
                               HorizontalAlignment="Center"
                               Margin="0,34,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Print"
                    Command="{Binding PrintCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="110"
                    Margin="0,0,10,0"
                    AutomationProperties.Name="Print receipt"/>
            <Button Content="Done" Width="110" Click="OnClose" AutomationProperties.Name="Close receipt"/>
        </StackPanel>
    </Grid>
</Window>

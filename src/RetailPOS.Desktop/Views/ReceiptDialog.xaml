<Window x:Class="RetailPOS.Desktop.Views.ReceiptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receipt" Width="700" Height="820" MinHeight="700"
        WindowStartupLocation="CenterOwner" Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <StackPanel>
                <TextBlock Text="Payment complete" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="{Binding StatusMessage}"
                           Style="{StaticResource SecondaryTextBlockStyle}"
                           Margin="0,6,0,0"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource DangerBrush}"
                           TextWrapping="Wrap"
                           Margin="0,6,140,0"/>
            </StackPanel>
            <Border Style="{StaticResource StatusPillStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top">
                <TextBlock Text="PAID"
                           Foreground="{StaticResource SuccessBrush}"
                           FontWeight="SemiBold"/>
            </Border>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Margin="56,24" Padding="34">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{Binding StoreName}"
                               FontSize="20"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding StoreAddress}"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,18"/>

                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Receipt" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding OrderNumber}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Business date" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding BusinessDateText}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Issued" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding IssuedAtText}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,6">
                        <TextBlock Text="Cashier" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding CashierName}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,18">
                        <TextBlock Text="Register" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding RegisterName}" HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator/>
                    <ItemsControl ItemsSource="{Binding Lines}" Margin="0,18,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding UnitPriceText}"
                                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                                   Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding DiscountAmountText}"
                                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding QuantityText}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TotalAmountText}"
                                               HorizontalAlignment="Right"
                                               FontWeight="SemiBold"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator/>
                    <Grid Margin="0,18,0,8">
                        <TextBlock Text="Subtotal" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding SubtotalAmount}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Discount" Style="{StaticResource SecondaryTextBlockStyle}"/>
                        <TextBlock Text="{Binding DiscountAmount}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,18">
                        <TextBlock Text="Total" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding TotalAmount}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"/>
                    </Grid>

                    <Separator/>
                    <ItemsControl ItemsSource="{Binding Payments}" Margin="0,18,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding MethodText}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding ApprovalCodeText}"
                                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding AmountText}"
                                               HorizontalAlignment="Right"
                                               Foreground="{StaticResource SuccessBrush}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Thank you for shopping with us."
                               HorizontalAlignment="Center"
                               Margin="0,34,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Print"
                    Command="{Binding PrintCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="110"
                    Margin="0,0,10,0"/>
            <Button Content="Done" Width="110" Click="OnClose"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="RetailPOS.Desktop.Views.ReceiptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Receipt" Width="640" Height="760" MinHeight="680"
        WindowStartupLocation="CenterOwner" Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="32">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Grid><StackPanel><TextBlock Text="Payment complete" Style="{StaticResource TitleTextBlockStyle}"/><TextBlock Text="Receipt preview" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,6,0,0"/></StackPanel><Border Style="{StaticResource StatusPillStyle}" HorizontalAlignment="Right" VerticalAlignment="Top"><TextBlock Text="PAID" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"/></Border></Grid>
        <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Margin="70,24" Padding="36">
            <StackPanel><TextBlock Text="RETAIL POS" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/><TextBlock Text="Receipt #000124" Style="{StaticResource SecondaryTextBlockStyle}" HorizontalAlignment="Center" Margin="0,6,0,24"/><Separator/><Grid Margin="0,22,0,12"><TextBlock Text="Daily Shampoo  x1"/><TextBlock Text="₩2,000" HorizontalAlignment="Right"/></Grid><Grid Margin="0,0,0,12"><TextBlock Text="Vitamin Drink  x1"/><TextBlock Text="₩5,000" HorizontalAlignment="Right"/></Grid><Grid Margin="0,0,0,22"><TextBlock Text="Hand Cream  x1"/><TextBlock Text="₩8,000" HorizontalAlignment="Right"/></Grid><Separator/><Grid Margin="0,22,0,8"><TextBlock Text="Total" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="{Binding TotalAmount}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Right"/></Grid><Grid><TextBlock Text="Card" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="Approved" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Right"/></Grid><TextBlock Text="Thank you for shopping with us." HorizontalAlignment="Center" Margin="0,40,0,0"/></StackPanel>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Print" Style="{StaticResource SecondaryButtonStyle}" Width="110" Margin="0,0,10,0"/><Button Content="Done" Width="110" Click="OnClose"/></StackPanel>
    </Grid>
</Window>

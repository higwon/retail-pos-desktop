<UserControl x:Class="RetailPOS.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource AppBackgroundBrush}">
        <StackPanel Margin="32">
            <Grid Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock Text="Operations dashboard" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock Text="Today | Register overview"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               Margin="0,6,0,0" />
                    <TextBlock Text="{Binding LastUpdatedText}"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               FontSize="11"
                               Margin="0,6,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <TextBlock Text="{Binding ConnectivityText}"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0" />
                    <Button Content="Refresh"
                            Command="{Binding RefreshCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            MinWidth="88"
                            Margin="0,0,12,0" />
                    <Border Style="{StaticResource StatusPillStyle}"
                            Background="{Binding DashboardStatusBackground}">
                        <TextBlock Text="{Binding DashboardStatusText}"
                                   Foreground="{Binding DashboardStatusForeground}"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Grid>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       Margin="0,0,0,16"
                       Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <UniformGrid Columns="4" Margin="0,0,0,20">
                <Border Style="{StaticResource PanelBorderStyle}" Padding="20" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Net sales" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{Binding NetSalesText}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" />
                        <TextBlock Text="{Binding AverageOrderText}" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource PanelBorderStyle}" Padding="20" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Orders" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{Binding OrderCountText}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" />
                        <TextBlock Text="Completed today" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource PanelBorderStyle}" Padding="20" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Sync queue" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{Binding PendingSyncText}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" />
                        <TextBlock Text="{Binding RetrySyncText}" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource PanelBorderStyle}" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Recovery" Style="{StaticResource SecondaryTextBlockStyle}" />
                        <TextBlock Text="{Binding CheckoutRecoveryText}" FontSize="24" FontWeight="Bold" Margin="0,10,0,0" />
                        <TextBlock Text="{Binding SyncReviewText}" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Recent local orders" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16" />
                        <Grid Background="{StaticResource AppBackgroundBrush}" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ORDER" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="TIME" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="STATUS" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="TOTAL" FontWeight="SemiBold" HorizontalAlignment="Right" />
                        </Grid>
                        <ItemsControl ItemsSource="{Binding RecentOrders}"
                                      Visibility="{Binding HasRecentOrders, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding OrderNumber}" />
                                        <TextBlock Grid.Column="1" Text="{Binding CreatedAtText}" />
                                        <TextBlock Grid.Column="2" Text="{Binding StatusText}" Foreground="{StaticResource SuccessBrush}" />
                                        <TextBlock Grid.Column="3" Text="{Binding TotalText}" HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding EmptyRecentOrdersText}"
                                   Style="{StaticResource SecondaryTextBlockStyle}"
                                   Margin="0,16,0,0"
                                   Visibility="{Binding HasNoRecentOrders, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Needs attention" FontSize="18" FontWeight="SemiBold" />
                        <Border Background="{Binding AttentionBackground}" CornerRadius="6" Padding="14" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="{Binding AttentionTitle}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding AttentionDetail}"
                                           Style="{StaticResource SecondaryTextBlockStyle}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>

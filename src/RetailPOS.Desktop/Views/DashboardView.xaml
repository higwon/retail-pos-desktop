<UserControl x:Class="RetailPOS.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource AppBackgroundBrush}">
        <StackPanel Margin="32">
            <Grid Margin="0,0,0,24"><StackPanel><TextBlock Text="Operations dashboard" Style="{StaticResource TitleTextBlockStyle}"/><TextBlock Text="Today · Register overview" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,6,0,0"/></StackPanel><Border Style="{StaticResource StatusPillStyle}" HorizontalAlignment="Right" VerticalAlignment="Top"><TextBlock Text="ALL SYSTEMS NORMAL" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"/></Border></Grid>
            <UniformGrid Columns="4" Margin="0,0,0,20">
                <Border Style="{StaticResource PanelBorderStyle}" Padding="20" Margin="0,0,12,0"><StackPanel><TextBlock Text="Net sales" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="₩1,284,000" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/><TextBlock Text="+8.4% from yesterday" Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0"/></StackPanel></Border>
                <Border Style="{StaticResource PanelBorderStyle}" Padding="20" Margin="0,0,12,0"><StackPanel><TextBlock Text="Orders" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="86" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/><TextBlock Text="Average ₩14,930" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,8,0,0"/></StackPanel></Border>
                <Border Style="{StaticResource PanelBorderStyle}" Padding="20" Margin="0,0,12,0"><StackPanel><TextBlock Text="Pending sync" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="3" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/><TextBlock Text="Oldest 4 min ago" Foreground="{StaticResource WarningBrush}" Margin="0,8,0,0"/></StackPanel></Border>
                <Border Style="{StaticResource PanelBorderStyle}" Padding="20"><StackPanel><TextBlock Text="Register uptime" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="7h 42m" FontSize="24" FontWeight="Bold" Margin="0,10,0,0"/><TextBlock Text="Online" Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0"/></StackPanel></Border>
            </UniformGrid>
            <Grid Margin="0,0,0,20"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Style="{StaticResource PanelBorderStyle}" Padding="24"><StackPanel><TextBlock Text="Sales by hour" FontSize="18" FontWeight="SemiBold"/><Grid Height="210" Margin="0,24,0,0" VerticalAlignment="Bottom"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Rectangle Grid.Column="0" Height="60" Fill="{StaticResource PrimaryBrush}" VerticalAlignment="Bottom" Margin="10,0"/><Rectangle Grid.Column="1" Height="100" Fill="{StaticResource PrimaryBrush}" VerticalAlignment="Bottom" Margin="10,0"/><Rectangle Grid.Column="2" Height="82" Fill="{StaticResource PrimaryBrush}" VerticalAlignment="Bottom" Margin="10,0"/><Rectangle Grid.Column="3" Height="150" Fill="{StaticResource PrimaryBrush}" VerticalAlignment="Bottom" Margin="10,0"/><Rectangle Grid.Column="4" Height="126" Fill="{StaticResource PrimaryBrush}" VerticalAlignment="Bottom" Margin="10,0"/><Rectangle Grid.Column="5" Height="178" Fill="{StaticResource PrimaryBrush}" VerticalAlignment="Bottom" Margin="10,0"/><Rectangle Grid.Column="6" Height="142" Fill="{StaticResource PrimaryBrush}" VerticalAlignment="Bottom" Margin="10,0"/><Rectangle Grid.Column="7" Height="192" Fill="{StaticResource PrimaryBrush}" VerticalAlignment="Bottom" Margin="10,0"/></Grid></StackPanel></Border>
                <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="24"><StackPanel><TextBlock Text="Needs attention" FontSize="18" FontWeight="SemiBold"/><Border Background="{StaticResource WarningMutedBrush}" CornerRadius="6" Padding="14" Margin="0,20,0,10"><StackPanel><TextBlock Text="3 orders waiting to sync" FontWeight="SemiBold"/><TextBlock Text="Network is available" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,4,0,0"/></StackPanel></Border><Border Background="{StaticResource DangerMutedBrush}" CornerRadius="6" Padding="14"><StackPanel><TextBlock Text="1 checkout needs review" FontWeight="SemiBold"/><TextBlock Text="Approval was recorded" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,4,0,0"/></StackPanel></Border></StackPanel></Border>
            </Grid>
            <Border Style="{StaticResource PanelBorderStyle}" Padding="24"><StackPanel><TextBlock Text="Recent orders" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/><Grid Background="{StaticResource AppBackgroundBrush}" Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="ORDER" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="TIME" FontWeight="SemiBold"/><TextBlock Grid.Column="2" Text="STATUS" FontWeight="SemiBold"/><TextBlock Grid.Column="3" Text="TOTAL" FontWeight="SemiBold" HorizontalAlignment="Right"/></Grid><Grid Margin="0,8"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="#000124"/><TextBlock Grid.Column="1" Text="15:42"/><TextBlock Grid.Column="2" Text="Completed" Foreground="{StaticResource SuccessBrush}"/><TextBlock Grid.Column="3" Text="₩15,000" HorizontalAlignment="Right"/></Grid></StackPanel></Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>

<Window x:Class="RetailPOS.Desktop.Views.DeviceSimulatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Device Simulator"
        Width="980"
        Height="780"
        MinWidth="860"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="28,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Device Simulator" Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock Text="Local peripheral controls"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Style="{StaticResource StatusPillStyle}"
                        Background="{StaticResource WarningMutedBrush}"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0">
                    <TextBlock Text="{Binding EnvironmentName}"
                               Foreground="{StaticResource WarningBrush}"
                               FontWeight="SemiBold"/>
                </Border>
                <Button Grid.Column="2"
                        Content="Close"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinHeight="36"
                        Padding="14,4"
                        Click="OnClose"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="28,22,28,28">
            <TabItem Header="Barcode Scanner">
                <Grid Margin="0,18,0,0" DataContext="{Binding BarcodeScanner}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Connection" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <TextBlock Text="{Binding ConnectionState}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Connect"
                                        Command="{Binding ConnectCommand}"
                                        Style="{StaticResource PrimaryBlueButtonStyle}"
                                        MinWidth="96"
                                        Margin="0,0,8,0"/>
                                <Button Content="Disconnect"
                                        Command="{Binding DisconnectCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        MinWidth="96"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Barcode" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"/>
                            <CheckBox Content="Raise callback on a background thread"
                                      IsChecked="{Binding EmitOnBackgroundThread}"
                                      Margin="0,14,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Emit Scan"
                                Command="{Binding EmitScanCommand}"
                                Style="{StaticResource PrimaryBlueButtonStyle}"
                                MinWidth="110"
                                VerticalAlignment="Bottom"/>
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,20,0,0">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource SuccessBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Receipt Printer">
                <Grid Margin="0,18,0,0" DataContext="{Binding ReceiptPrinter}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Connection" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <TextBlock Text="{Binding ConnectionState}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Current state" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <TextBlock Text="{Binding OperationalState}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Connect"
                                        Command="{Binding ConnectCommand}"
                                        Style="{StaticResource PrimaryBlueButtonStyle}"
                                        MinWidth="96"
                                        Margin="0,0,8,0"/>
                                <Button Content="Disconnect"
                                        Command="{Binding DisconnectCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        MinWidth="96"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource PanelBorderStyle}" Padding="22">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Pending request" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <StackPanel Grid.Row="1" Margin="0,5,0,14">
                                    <TextBlock Text="{Binding PendingRequestTitle}" FontSize="19" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding PendingRequestMetadata}" TextWrapping="Wrap"
                                               Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,5,0,0"/>
                                </StackPanel>
                                <TextBox Grid.Row="2" Text="{Binding PrintableText}" IsReadOnly="True"
                                         FontFamily="Consolas" TextWrapping="NoWrap"
                                         Padding="12,10"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         MinHeight="220"/>
                                <StackPanel Grid.Row="3" Margin="0,16,0,0">
                                    <TextBlock Text="Response" FontWeight="SemiBold" Margin="0,0,0,7"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <ComboBox ItemsSource="{Binding Outcomes}" SelectedItem="{Binding SelectedOutcome}"
                                                  DisplayMemberPath="Label" MinWidth="220" MinHeight="44"
                                                  VerticalContentAlignment="Center" Padding="10,4"/>
                                        <Button Grid.Column="1" Content="Send response" Command="{Binding RespondCommand}"
                                                Style="{StaticResource PrimaryBlueButtonStyle}" MinWidth="138" Margin="12,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="22">
                            <StackPanel>
                                <TextBlock Text="Recent completed requests" FontWeight="SemiBold"/>
                                <ItemsControl ItemsSource="{Binding RecentRequests}" Margin="0,12,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ReceiptIdentity}" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
                                                        <Border Grid.Column="1" Background="{StaticResource AppBackgroundBrush}"
                                                                CornerRadius="10" Padding="8,2">
                                                            <TextBlock Text="{Binding Outcome}" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding CompletedAtText}" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,18,0,0">
                        <StackPanel>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource SuccessBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                        </StackPanel>
                        <Button Content="Reset state" Command="{Binding ResetCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Right" MinWidth="110"/>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Card Terminal">
                <StackPanel Margin="0,18,0,0" DataContext="{Binding CardTerminal}">
                    <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Connection" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="{Binding ConnectionState}" FontSize="18" FontWeight="SemiBold"/></StackPanel>
                            <StackPanel Grid.Column="1"><TextBlock Text="Current state" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="{Binding OperationalState}" FontSize="18" FontWeight="SemiBold"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="Last outcome" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="{Binding LastOutcome}" FontSize="18" FontWeight="SemiBold"/></StackPanel>
                            <StackPanel Grid.Column="3" Orientation="Horizontal"><Button Content="Connect" Command="{Binding ConnectCommand}" Style="{StaticResource PrimaryBlueButtonStyle}" Margin="0,0,8,0"/><Button Content="Disconnect" Command="{Binding DisconnectCommand}" Style="{StaticResource SecondaryButtonStyle}"/></StackPanel>
                        </Grid>
                    </Border>
                    <Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="18"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="Next outcome" FontWeight="SemiBold"/><ComboBox ItemsSource="{Binding Scenarios}" SelectedItem="{Binding SelectedScenario}"/></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="Response delay (ms)" FontWeight="SemiBold"/><TextBox Text="{Binding ResponseDelayMilliseconds, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0"><Button Content="Reset" Command="{Binding ResetCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/><Button Content="Apply" Command="{Binding ApplyCommand}" Style="{StaticResource PrimaryBlueButtonStyle}"/></StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}" Margin="0,18,0,0"/><TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Customer Display">
                <StackPanel Margin="0,18,0,0" DataContext="{Binding CustomerDisplay}">
                    <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                        <StackPanel>
                            <TextBlock Text="Secondary monitor" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding Targets}" SelectedItem="{Binding SelectedTarget}" DisplayMemberPath="Name" Margin="0,8,0,16"/>
                            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SecondaryTextBlockStyle}" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                                <Button Content="Close" Command="{Binding CloseCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>
                                <Button Content="Open" Command="{Binding OpenCommand}" Style="{StaticResource PrimaryBlueButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

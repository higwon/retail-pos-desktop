<Window x:Class="RetailPOS.Desktop.Views.DeviceSimulatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Device Simulator"
        Width="780"
        Height="680"
        MinWidth="700"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="28,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Device Simulator" Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock Text="Local peripheral controls"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Style="{StaticResource StatusPillStyle}"
                        Background="{StaticResource WarningMutedBrush}"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0">
                    <TextBlock Text="{Binding EnvironmentName}"
                               Foreground="{StaticResource WarningBrush}"
                               FontWeight="SemiBold"/>
                </Border>
                <Button Grid.Column="2"
                        Content="Close"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinHeight="36"
                        Padding="14,4"
                        Click="OnClose"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="28,22,28,28">
            <TabItem Header="Barcode Scanner">
                <Grid Margin="0,18,0,0" DataContext="{Binding BarcodeScanner}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Connection" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <TextBlock Text="{Binding ConnectionState}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Connect"
                                        Command="{Binding ConnectCommand}"
                                        Style="{StaticResource PrimaryBlueButtonStyle}"
                                        MinWidth="96"
                                        Margin="0,0,8,0"/>
                                <Button Content="Disconnect"
                                        Command="{Binding DisconnectCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        MinWidth="96"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Barcode" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"/>
                            <CheckBox Content="Raise callback on a background thread"
                                      IsChecked="{Binding EmitOnBackgroundThread}"
                                      Margin="0,14,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Emit Scan"
                                Command="{Binding EmitScanCommand}"
                                Style="{StaticResource PrimaryBlueButtonStyle}"
                                MinWidth="110"
                                VerticalAlignment="Bottom"/>
                    </Grid>

                    <StackPanel Grid.Row="2" Margin="0,20,0,0">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource SuccessBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Receipt Printer">
                <Grid Margin="0,18,0,0" DataContext="{Binding ReceiptPrinter}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Connection" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <TextBlock Text="{Binding ConnectionState}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Current state" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <TextBlock Text="{Binding OperationalState}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Connect"
                                        Command="{Binding ConnectCommand}"
                                        Style="{StaticResource PrimaryBlueButtonStyle}"
                                        MinWidth="96"
                                        Margin="0,0,8,0"/>
                                <Button Content="Disconnect"
                                        Command="{Binding DisconnectCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        MinWidth="96"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Next outcome" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding Outcomes}"
                                      SelectedItem="{Binding SelectedOutcome}"
                                      DisplayMemberPath="Label"
                                      MinHeight="44"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Response delay (ms)" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding ResponseDelayMilliseconds, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,22,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Reset"
                                    Command="{Binding ResetCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    MinWidth="96"
                                    Margin="0,0,10,0"/>
                            <Button Content="Apply"
                                    Command="{Binding ApplyCommand}"
                                    Style="{StaticResource PrimaryBlueButtonStyle}"
                                    MinWidth="96"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="3" Margin="0,20,0,0">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource SuccessBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

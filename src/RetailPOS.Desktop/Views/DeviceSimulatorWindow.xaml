<Window x:Class="RetailPOS.Desktop.Views.DeviceSimulatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Device Simulator"
        Width="980"
        Height="780"
        MinWidth="860"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}"
        KeyboardNavigation.TabNavigation="Cycle"
        AutomationProperties.Name="Device simulator">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Style x:Key="SimulatorStateTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Style.Triggers>
                <Trigger Property="Text" Value="Connected"><Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/></Trigger>
                <Trigger Property="Text" Value="Ready"><Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/></Trigger>
                <Trigger Property="Text" Value="Idle"><Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/></Trigger>
                <Trigger Property="Text" Value="Approved"><Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/></Trigger>
                <Trigger Property="Text" Value="Open"><Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/></Trigger>
                <Trigger Property="Text" Value="Printing"><Setter Property="Foreground" Value="{StaticResource PrimaryBlueBrush}"/></Trigger>
                <Trigger Property="Text" Value="Processing"><Setter Property="Foreground" Value="{StaticResource PrimaryBlueBrush}"/></Trigger>
                <Trigger Property="Text" Value="Disconnected"><Setter Property="Foreground" Value="{StaticResource DangerBrush}"/></Trigger>
                <Trigger Property="Text" Value="Closed"><Setter Property="Foreground" Value="{StaticResource DangerBrush}"/></Trigger>
                <Trigger Property="Text" Value="Faulted"><Setter Property="Foreground" Value="{StaticResource DangerBrush}"/></Trigger>
                <Trigger Property="Text" Value="Unknown"><Setter Property="Foreground" Value="{StaticResource WarningBrush}"/></Trigger>
                <Trigger Property="Text" Value="Cancelled"><Setter Property="Foreground" Value="{StaticResource WarningBrush}"/></Trigger>
                <Trigger Property="Text" Value="Declined"><Setter Property="Foreground" Value="{StaticResource DangerBrush}"/></Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SimulatorTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FocusVisualStyle" Value="{StaticResource KeyboardFocusVisualStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabSurface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabSurface" Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
                                <Setter TargetName="TabSurface" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="TabSurface" Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="TabSurface" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SimulatorTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Background="{StaticResource SecondaryButtonBrush}"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    CornerRadius="8"
                                    Padding="4">
                                <TabPanel IsItemsHost="True" KeyboardNavigation.TabIndex="1"/>
                            </Border>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Grid.Row="1"
                                              ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SimulatorComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemSurface"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemSurface" Property="Background" Value="{StaticResource SecondaryButtonBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemSurface" Property="Background" Value="{StaticResource SecondaryButtonBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryHoverBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SimulatorComboBoxStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SimulatorComboBoxItemStyle}"/>
            <Setter Property="MaxDropDownHeight" Value="280"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="InputBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <ToggleButton x:Name="DropDownToggle"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Grid Background="Transparent">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Margin="12,0,8,0"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding Text, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Border Grid.Column="1" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                                                    <Path Data="{StaticResource IconChevronDownGeometry}"
                                                          Style="{StaticResource IconPathStyle}"
                                                          Width="12" Height="12"
                                                          Stroke="{StaticResource TextSecondaryBrush}"/>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, ElementName=InputBorder}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,5,0,0"
                                        Padding="3"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="InputBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="InputBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="28,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Device Simulator" Style="{StaticResource TitleTextBlockStyle}"/>
                    <TextBlock Text="Local peripheral controls"
                               Style="{StaticResource SecondaryTextBlockStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Column="1"
                        Style="{StaticResource StatusPillStyle}"
                        Background="{StaticResource WarningMutedBrush}"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0">
                    <TextBlock Text="{Binding EnvironmentName}"
                               Foreground="{StaticResource WarningBrush}"
                               FontWeight="SemiBold"/>
                </Border>
                <Button Grid.Column="2"
                        Content="Close"
                        Style="{StaticResource SecondaryButtonStyle}"
                        MinHeight="36"
                        Padding="14,4"
                        Click="OnClose"
                        AutomationProperties.Name="Close device simulator"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="28,20,28,28"
                    Style="{StaticResource SimulatorTabControlStyle}"
                    ItemContainerStyle="{StaticResource SimulatorTabItemStyle}"
                    AutomationProperties.Name="Simulated devices">
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconScannerGeometry}" Style="{StaticResource IconPathStyle}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" Margin="0,0,8,0"/>
                        <TextBlock Text="Barcode Scanner" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" FontWeight="SemiBold"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,16,0,0" DataContext="{Binding BarcodeScanner}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Connection" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <TextBlock Text="{Binding ConnectionState}"
                                           Style="{StaticResource SimulatorStateTextStyle}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button
                                        Command="{Binding ConnectCommand}"
                                        Style="{StaticResource PrimaryBlueButtonStyle}"
                                        MinWidth="96"
                                        Margin="0,0,8,0"><TextBlock Text="Connect" Style="{StaticResource PrimaryButtonLabelTextStyle}"/></Button>
                                <Button Content="Disconnect"
                                        Command="{Binding DisconnectCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        MinWidth="96"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,16,0,0">
                        <RadioButton Content="Product Picker" IsChecked="{Binding IsProductPickerMode}" FontWeight="SemiBold" Margin="0,0,22,0"/>
                        <RadioButton Content="Manual Barcode" IsChecked="{Binding IsManualBarcodeMode}" FontWeight="SemiBold"/>
                        <CheckBox Content="Background callback" IsChecked="{Binding EmitOnBackgroundThread}" Margin="28,0,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="0,14,0,0">
                        <Border Style="{StaticResource PanelBorderStyle}" Padding="20"
                                Visibility="{Binding IsProductPickerMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="16"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Search products" FontWeight="SemiBold"/><TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,7,0,0" AutomationProperties.Name="Search scanner products"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="Category" FontWeight="SemiBold"/><ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Style="{StaticResource SimulatorComboBoxStyle}" Margin="0,7,0,0" AutomationProperties.Name="Scanner product category"/></StackPanel>
                                </Grid>
                                <ListBox Grid.Row="1" ItemsSource="{Binding Products}" SelectedItem="{Binding SelectedProduct}"
                                         Margin="0,14,0,0" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" Background="{StaticResource SurfaceBrush}"
                                         ScrollViewer.CanContentScroll="True" VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling">
                                    <ListBox.ItemsPanel><ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate></ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="ProductRow"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ProductRow" Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="ProductRow" Property="Background" Value="{StaticResource SecondaryButtonBrush}"/>
                                                                <Setter TargetName="ProductRow" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                                <Setter TargetName="ProductRow" Property="BorderThickness" Value="3,0,0,1"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate><DataTemplate>
                                        <Grid Margin="6,8"><Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions>
                                            <StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/><TextBlock Text="{Binding Barcode}" Style="{StaticResource SecondaryTextBlockStyle}"/></StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Sku}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="2" Text="{Binding CategoryName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="3" Text="{Binding UnitPrice, StringFormat={}{0:N0} KRW}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate></ListBox.ItemTemplate>
                                </ListBox>
                                <Grid Grid.Row="2" Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Selected barcode" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="{Binding SelectedBarcodePreview}" FontSize="18" FontWeight="SemiBold"/></StackPanel>
                                    <Button Grid.Column="1" Command="{Binding EmitScanCommand}" Style="{StaticResource PrimaryBlueButtonStyle}" MinWidth="120"><TextBlock Text="Emit Scan" Style="{StaticResource PrimaryButtonLabelTextStyle}"/></Button>
                                </Grid>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource PanelBorderStyle}" Padding="24"
                                Visibility="{Binding IsManualBarcodeMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Manual barcode" FontSize="18" FontWeight="SemiBold"/>
                                <TextBlock Text="Use this mode for unknown or error-path testing." Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,5,0,16"/>
                                <TextBox Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"/>
                                <Grid Margin="0,14,0,0"><TextBlock Text="{Binding SelectedBarcodePreview}" FontWeight="SemiBold" VerticalAlignment="Center"/><Button Command="{Binding EmitScanCommand}" Style="{StaticResource PrimaryBlueButtonStyle}" HorizontalAlignment="Right" MinWidth="120"><TextBlock Text="Emit Scan" Style="{StaticResource PrimaryButtonLabelTextStyle}"/></Button></Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="3" Margin="0,16,0,0">
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource SuccessBrush}"
                                   TextWrapping="Wrap"
                                   AutomationProperties.LiveSetting="Polite"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   AutomationProperties.LiveSetting="Assertive"/>
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconReceiptGeometry}" Style="{StaticResource IconPathStyle}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" Margin="0,0,8,0"/>
                        <TextBlock Text="Receipt Printer" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" FontWeight="SemiBold"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,16,0,0" DataContext="{Binding ReceiptPrinter}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Connection" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <TextBlock Text="{Binding ConnectionState}"
                                           Style="{StaticResource SimulatorStateTextStyle}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Current state" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <TextBlock Text="{Binding OperationalState}"
                                           Style="{StaticResource SimulatorStateTextStyle}"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button
                                        Command="{Binding ConnectCommand}"
                                        Style="{StaticResource PrimaryBlueButtonStyle}"
                                        MinWidth="96"
                                        Margin="0,0,8,0"><TextBlock Text="Connect" Style="{StaticResource PrimaryButtonLabelTextStyle}"/></Button>
                                <Button Content="Disconnect"
                                        Command="{Binding DisconnectCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        MinWidth="96"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource PanelBorderStyle}" Padding="22">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Pending request" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <StackPanel Grid.Row="1" Margin="0,5,0,14">
                                    <TextBlock Text="{Binding PendingRequestTitle}" FontSize="19" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" ToolTip="{Binding PendingRequestTitle}"/>
                                    <TextBlock Text="{Binding PendingRequestMetadata}" TextWrapping="Wrap"
                                               Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,5,0,0"/>
                                </StackPanel>
                                <TextBox Grid.Row="2" Text="{Binding PrintableText}" IsReadOnly="True"
                                         FontFamily="Consolas" TextWrapping="NoWrap"
                                         Padding="12,10"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         MinHeight="220"/>
                                <StackPanel Grid.Row="3" Margin="0,16,0,0">
                                    <TextBlock Text="Response" FontWeight="SemiBold" Margin="0,0,0,7"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <ComboBox ItemsSource="{Binding Outcomes}" SelectedItem="{Binding SelectedOutcome}"
                                                  DisplayMemberPath="Label" TextSearch.TextPath="Label" MinWidth="220"
                                                  Style="{StaticResource SimulatorComboBoxStyle}"
                                                  AutomationProperties.Name="Receipt printer response"/>
                                        <Button Grid.Column="1" Command="{Binding RespondCommand}"
                                                Style="{StaticResource PrimaryBlueButtonStyle}" MinWidth="138" Margin="12,0,0,0"><TextBlock Text="Send response" Style="{StaticResource PrimaryButtonLabelTextStyle}"/></Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="22">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Recent completed requests" FontWeight="SemiBold"/>
                                <ListBox Grid.Row="1" ItemsSource="{Binding RecentRequests}"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         BorderThickness="0" Background="Transparent"
                                         Margin="0,12,0,0" Padding="0">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding ReceiptIdentity}" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" Margin="0,0,10,0"/>
                                                        <Border Grid.Column="1" Background="{StaticResource AppBackgroundBrush}"
                                                                CornerRadius="10" Padding="8,2">
                                                            <TextBlock Text="{Binding Outcome}" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Text="{Binding CompletedAtText}" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <StackPanel>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{StaticResource SuccessBrush}"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="{StaticResource DangerBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>
                        </StackPanel>
                        <Button Content="Reset state" Command="{Binding ResetCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Right" MinWidth="110"/>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconCardGeometry}" Style="{StaticResource IconPathStyle}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" Margin="0,0,8,0"/>
                        <TextBlock Text="Card Terminal" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" FontWeight="SemiBold"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,16,0,0" DataContext="{Binding CardTerminal}">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="Connection" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="{Binding ConnectionState}" Style="{StaticResource SimulatorStateTextStyle}" Margin="0,6,0,0"/></StackPanel>
                            <StackPanel Grid.Column="1"><TextBlock Text="Current state" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="{Binding OperationalState}" Style="{StaticResource SimulatorStateTextStyle}" Margin="0,6,0,0"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="Last outcome" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Text="{Binding LastOutcome}" Style="{StaticResource SimulatorStateTextStyle}" Margin="0,6,0,0"/></StackPanel>
                            <StackPanel Grid.Column="3" Orientation="Horizontal"><Button Command="{Binding ConnectCommand}" Style="{StaticResource PrimaryBlueButtonStyle}" Margin="0,0,8,0"><TextBlock Text="Connect" Style="{StaticResource PrimaryButtonLabelTextStyle}"/></Button><Button Content="Disconnect" Command="{Binding DisconnectCommand}" Style="{StaticResource SecondaryButtonStyle}"/></StackPanel>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1" Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="5*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="3*"/></Grid.ColumnDefinitions>
                        <Border Style="{StaticResource PanelBorderStyle}" Padding="22">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <TextBlock Text="Pending authorization" FontWeight="SemiBold" FontSize="18"/>
                                <Grid Grid.Row="1" Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="145"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="Amount" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Grid.Column="1" Text="{Binding RequestedAmount}" FontSize="20" FontWeight="Bold"/></Grid>
                                <Grid Grid.Row="2" Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="145"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="Payment attempt" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBlock Grid.Column="1" Text="{Binding PaymentAttemptId}" TextTrimming="CharacterEllipsis"/></Grid>
                                <Grid Grid.Row="3" Margin="0,6,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="145"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Text="Request / received" Style="{StaticResource SecondaryTextBlockStyle}"/><StackPanel Grid.Column="1"><TextBlock Text="{Binding RequestId}" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding RequestedAt}" Style="{StaticResource SecondaryTextBlockStyle}"/></StackPanel></Grid>
                                <StackPanel Grid.Row="4">
                                    <TextBlock Text="Terminal response" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding Responses}" SelectedItem="{Binding SelectedResponse}" Style="{StaticResource SimulatorComboBoxStyle}" Margin="0,5,0,8"/>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <StackPanel><TextBlock Text="Approval code" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBox Text="{Binding ApprovalCode, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                        <StackPanel Grid.Column="2"><TextBlock Text="Transaction reference" Style="{StaticResource SecondaryTextBlockStyle}"/><TextBox Text="{Binding TransactionReference, UpdateSourceTrigger=PropertyChanged}"/></StackPanel>
                                    </Grid>
                                    <Button Command="{Binding RespondCommand}" Style="{StaticResource PrimaryBlueButtonStyle}" HorizontalAlignment="Right" MinWidth="138" Height="44" Margin="0,10,0,0"><TextBlock Text="Send response" Style="{StaticResource PrimaryButtonLabelTextStyle}"/></Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Padding="22">
                            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <TextBlock Text="Recent authorizations" FontWeight="SemiBold"/>
                                <ListBox Grid.Row="1" ItemsSource="{Binding RecentRequests}"
                                         BorderThickness="0" Background="Transparent" Margin="0,12,0,0"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,9">
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding PaymentAttemptId}"
                                                                   TextWrapping="NoWrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,0,10,0"
                                                                   ToolTip="{Binding PaymentAttemptId}"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Outcome}" FontWeight="SemiBold"/>
                                                    </Grid>
                                                    <TextBlock Text="{Binding CompletedAt}" Style="{StaticResource SecondaryTextBlockStyle}" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Grid>
                    <Grid Grid.Row="2" Margin="0,16,0,0"><StackPanel><TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SuccessBrush}"/><TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}"/></StackPanel><Button Content="Reset state" Command="{Binding ResetCommand}" Style="{StaticResource SecondaryButtonStyle}" HorizontalAlignment="Right"/></Grid>
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconDisplayGeometry}" Style="{StaticResource IconPathStyle}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" Margin="0,0,8,0"/>
                        <TextBlock Text="Customer Display" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}" FontWeight="SemiBold"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="0,16,0,0" DataContext="{Binding CustomerDisplay}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Host state" Style="{StaticResource SecondaryTextBlockStyle}"/>
                                <TextBlock Margin="0,6,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource SimulatorStateTextStyle}">
                                            <Setter Property="Text" Value="Closed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOpen}" Value="True">
                                                    <Setter Property="Text" Value="Open"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Close" Command="{Binding CloseCommand}" Style="{StaticResource SecondaryButtonStyle}" MinWidth="96" Margin="0,0,8,0"/>
                                <Button Command="{Binding OpenCommand}" Style="{StaticResource PrimaryBlueButtonStyle}" MinWidth="96"><TextBlock Text="Open" Style="{StaticResource PrimaryButtonLabelTextStyle}"/></Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}" Padding="24" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Secondary monitor" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding Targets}" SelectedItem="{Binding SelectedTarget}" DisplayMemberPath="Name" TextSearch.TextPath="Name" Style="{StaticResource SimulatorComboBoxStyle}" Margin="0,8,0,16"/>
                            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SecondaryTextBlockStyle}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
